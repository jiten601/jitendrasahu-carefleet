@model CareFleet.Models.Doctor
@{
    ViewData["Title"] = "Edit Doctor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Doctors";
    ViewBag.HeaderTitle = "System Administration";
    ViewBag.HideHeader = true;
}

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" />
    <link rel="stylesheet" href="~/css/admin-premium-forms.css" />
}

<div class="premium-admin-container">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Modify Doctor Profile</h1>
                <p class="header-subtitle"><i class="fas fa-stethoscope me-2"></i> Update credentials and account details for Dr. @Model.FirstName @Model.LastName</p>
                <div style="margin-top: 30px !important; color:white">
                    <span class="badge rounded-pill" style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(5px); padding: 8px 16px; font-weight: 600;">
                        <i class="far fa-calendar-alt me-2"></i> Joined: @Model.CreatedAt.ToString("MMM dd, yyyy")
                    </span>
                </div>
            </div>
            <div class="header-actions">
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="@Url.Action("Doctors", "Admin")" class="btn-premium-light text-decoration-none">
                        <i class="fas fa-arrow-left me-2"></i> Back to Doctors List
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Doctor")" class="btn-premium-light text-decoration-none">
                        <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
                    </a>
                }
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="premium-form-container">
        <div class="premium-glass-card">
            <h2 class="form-section-title">
                <i class="fas fa-user-md text-primary"></i> Professional Information
            </h2>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="row">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="FirstName">First Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-user"></i>
                            <input asp-for="FirstName" class="premium-input" placeholder="e.g. Robert" required />
                        </div>
                        <span asp-validation-for="FirstName" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="LastName">Last Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-signature"></i>
                            <input asp-for="LastName" class="premium-input" placeholder="e.g. Smith" required />
                        </div>
                        <span asp-validation-for="LastName" class="validation-message"></span>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Email">Email Address</label>
                        <div class="input-group-premium">
                            <i class="fas fa-envelope"></i>
                            <input asp-for="Email" type="email" class="premium-input" placeholder="doctor@carefleet.com" required />
                        </div>
                        <span asp-validation-for="Email" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="PhoneNumber">Contact Number</label>
                        <div class="input-group-premium">
                            <i class="fas fa-phone"></i>
                            <input asp-for="PhoneNumber" class="premium-input" placeholder="+1 (555) 000-0000" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="validation-message"></span>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Specialization">Medical Specialization</label>
                        <div class="input-group-premium">
                            <i class="fas fa-briefcase-medical"></i>
                            <input asp-for="Specialization" class="premium-input" placeholder="e.g. Cardiology" required />
                        </div>
                        <span asp-validation-for="Specialization" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="LicenseNumber">Government License Map</label>
                        <div class="input-group-premium">
                            <i class="fas fa-id-card"></i>
                            <input asp-for="LicenseNumber" class="premium-input" placeholder="e.g. LIC-123456" required />
                        </div>
                        <span asp-validation-for="LicenseNumber" class="validation-message"></span>
                    </div>
                </div>

                <div class="form-group-premium mt-4 mb-4">
                    <div class="premium-status-toggle">
                        <input asp-for="IsActive" type="checkbox" id="isActive" class="premium-checkbox" />
                        <label for="isActive" class="premium-checkbox-label">
                            <div class="checkbox-box">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="checkbox-text">
                                <span class="d-block fw-bold" style="color: #1B3C53;">Active Account Status</span>
                                <span class="d-block text-muted" style="font-size: 0.8rem;">Deactivating will temporarily disable doctor access and visibility.</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="form-actions-premium">
                    <button type="submit" class="btn-premium-save">
                        <i class="fas fa-save"></i> Update Profile
                    </button>
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a href="@Url.Action("Doctors", "Admin")" class="btn-premium-cancel">
                            Cancel
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Index", "Doctor")" class="btn-premium-cancel">
                            Cancel
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Status Toggle Styling */
    .premium-status-toggle {
        background: rgba(255, 255, 255, 0.5);
        border: 1.5px solid #e2e8f0;
        border-radius: 16px;
        padding: 15px 20px;
        transition: all 0.3s ease;
    }

        .premium-status-toggle:hover {
            border-color: #456882;
            background: #ffffff;
        }

    .premium-checkbox {
        display: none;
    }

    .premium-checkbox-label {
        display: flex;
        align-items: center;
        gap: 15px;
        cursor: pointer;
        margin-bottom: 0;
    }

    .checkbox-box {
        width: 24px;
        height: 24px;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        background: #ffffff;
    }

        .checkbox-box i {
            font-size: 0.8rem;
            color: #ffffff;
            opacity: 0;
            transform: scale(0.5);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

    .premium-checkbox:checked + .premium-checkbox-label .checkbox-box {
        background: #10b981;
        border-color: #10b981;
    }

        .premium-checkbox:checked + .premium-checkbox-label .checkbox-box i {
            opacity: 1;
            transform: scale(1);
        }

    .premium-form-container {
        max-width: 900px;
        margin-top: -15px;
    }
</style>
