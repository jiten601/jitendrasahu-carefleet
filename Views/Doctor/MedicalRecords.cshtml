@model IEnumerable<CareFleet.Models.MedicalRecord>
@{
    ViewData["Title"] = "Patient Documentation";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewBag.ActivePage = "MedicalRecords";
    ViewBag.HeaderTitle = "Medical Records Access";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/doctor-records.css" asp-append-version="true" />
}

<div class="premium-admin-container doctor-records-page mt-4">
    <!-- Premium Header Card -->
    <div class="premium-header-card mb-4" style="background: linear-gradient(135deg, #1B3C53 0%, #3a506b 100%);">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Patient Medical Records</h1>
                <p class="header-subtitle">
                    <i class="fas fa-file-invoice me-2"></i>
                    Clinical history and diagnostic reports for your patients
                </p>

                <div class="header-stats-container d-flex gap-3 mt-4">
                    <div class="glass-stat-badge">
                        <span class="stat-label">Total Records</span>
                        <span class="stat-value">@ViewBag.TotalRecords</span>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("UploadRecord", "Doctor")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-upload me-2"></i> Upload Document
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Search & Filter Bar -->
    <form method="get" asp-action="MedicalRecords" id="filterForm">
        <div class="search-filter-section mb-4">
            <div class="search-input-wrapper flex-grow-1">
                <i class="fas fa-search"></i>
                <input type="text" name="searchString" id="recordSearch"
                       value="@ViewBag.CurrentFilter"
                       placeholder="Search by patient or document name..."
                       class="premium-search-input">
            </div>
            <div class="filter-actions h-100 d-flex gap-2">
                <select name="categoryFilter" id="doctorCategoryFilter" class="btn-filter" style="outline: none; cursor: pointer; min-width: 180px;" onchange="this.form.submit()">
                    <option value="All" selected="@(ViewBag.CategoryFilter == "All")">All Categories</option>
                    <option value="Laboratory" selected="@(ViewBag.CategoryFilter == "Laboratory")">Laboratory Results</option>
                    <option value="Radiology" selected="@(ViewBag.CategoryFilter == "Radiology")">Imaging & Radiology</option>
                    <option value="Physical" selected="@(ViewBag.CategoryFilter == "Physical")">Physical Assessment</option>
                    <option value="Prescription" selected="@(ViewBag.CategoryFilter == "Prescription")">Prescriptions</option>
                </select>
                <a href="@Url.Action("MedicalRecords")" class="btn-filter text-decoration-none d-flex align-items-center justify-content-center">
                    <i class="fas fa-sync-alt"></i>
                </a>
            </div>
        </div>
    </form>

    <!-- Table Glass Wrapper -->
    <div class="table-glass-wrapper shadow-lg overflow-visible">
        <table class="premium-table" id="recordsTable">
            <thead>
                <tr>
                    <th class="ps-5">Patient Name</th>
                    <th>Record Type</th>
                    <th>Date Upload</th>
                    <th class="text-center">Category</th>
                    <th class="text-center pe-5">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var record in Model)
                    {
                        var initials = record.Patient != null ?
                        (record.Patient.FirstName[0].ToString() + (record.Patient.LastName?.Length > 0 ? record.Patient.LastName[0].ToString() : "")).ToUpper() : "PA";

                        <tr class="doctor-record-row" data-category="@record.Category">
                            <td class="ps-5">
                                <div class="patient-identity">
                                    <div class="patient-avatar" style="background: rgba(27, 60, 83, 0.08); color: #1B3C53; font-weight: 800;">
                                        @initials
                                    </div>
                                    <div class="patient-info">
                                        <span class="patient-name">@(record.Patient != null ? $"{record.Patient.FirstName} {record.Patient.LastName}" : "Unknown Patient")</span>
                                        <span class="patient-id">PAT-ID: #P-@(record.Patient?.Id.ToString("D4") ?? "0000")</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="category-icon-box">
                                        <i class="fas @(record.Category == "Laboratory" ? "fa-vials" : record.Category == "Radiology" ? "fa-x-ray" : "fa-file-medical-alt")"></i>
                                    </div>
                                    <div class="patient-info">
                                        <span class="patient-name">@record.DocumentName</span>
                                        <span class="patient-id">Type: @record.FileType</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="data-label fw-600">@record.DateIssued.ToString("MMM dd, yyyy")</span>
                                <span class="data-sublabel">At: @record.DateIssued.ToString("hh:mm tt")</span>
                            </td>
                            <td class="text-center">
                                <span class="status-pill active" title="Finalized Report">
                                    <i class="fas fa-check-double small me-1 opacity-75"></i> @record.Category
                                </span>
                            </td>
                            <td class="pe-5">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <a href="@Url.Action("DownloadRecord", "Doctor", new { id = record.Id })"
                                       class="btn-action-premium view" title="Download Record">
                                        <i class="fas fa-download"></i>
                                    </a>
                                    <a href="@Url.Action("EditRecord", "Doctor", new { id = record.Id })"
                                       class="btn-action-premium edit" title="Edit Metadata">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="DeleteRecord" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@record.Id" />
                                        <button type="submit" class="btn-action-premium delete" title="Delete Permanent">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 100px;">
                            <div class="empty-state">
                                <i class="fas fa-folder-open mb-4" style="font-size: 4.5rem; color: #cbd5e1; opacity: 0.4;"></i>
                                <h3 style="color: #64748b; font-family: 'Outfit', sans-serif; font-weight: 700;">No Documentation Found</h3>
                                <p style="color: #94a3b8; font-weight: 500;">No records found matching your filter criteria.</p>
                                <a href="@Url.Action("MedicalRecords")" class="btn btn-primary mt-3">Clear Filters</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Premium Pagination -->
        @if (ViewBag.TotalRecords > 0)
        {
            <div class="premium-pagination-container">
                <div class="pagination-info">
                    @{
                        int start = (ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1;
                        int end = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalRecords);
                    }
                    Showing <span class="text-dark fw-bold">@start</span> to <span class="text-dark fw-bold">@end</span> of <span class="text-dark fw-bold">@ViewBag.TotalRecords</span> records
                </div>
                
                <div class="pagination-controls">
                    <a href="@Url.Action("MedicalRecords", new { page = ViewBag.CurrentPage - 1, searchString = ViewBag.CurrentFilter, categoryFilter = ViewBag.CategoryFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage <= 1 ? "disabled" : "")" title="Previous Page">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @if (ViewBag.TotalPages > 1)
                    {
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                            {
                                <a href="@Url.Action("MedicalRecords", new { page = i, searchString = ViewBag.CurrentFilter, categoryFilter = ViewBag.CategoryFilter })" 
                                   class="page-link-premium @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                            }
                            else if (i == ViewBag.CurrentPage - 3 || i == ViewBag.CurrentPage + 3)
                            {
                                <span class="px-2 text-muted">...</span>
                            }
                        }
                    }
                    else if (ViewBag.TotalPages == 1)
                    {
                        <a href="#" class="page-link-premium active">1</a>
                    }

                    <a href="@Url.Action("MedicalRecords", new { page = ViewBag.CurrentPage + 1, searchString = ViewBag.CurrentFilter, categoryFilter = ViewBag.CategoryFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")" title="Next Page">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('recordSearch');
            const filterForm = document.getElementById('filterForm');
            
            let typingTimer;
            const doneTypingInterval = 800;

            searchInput?.addEventListener('keyup', function() {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => {
                    filterForm.submit();
                }, doneTypingInterval);
            });

            searchInput?.addEventListener('keydown', function() {
                clearTimeout(typingTimer);
            });
        });
    </script>
}
