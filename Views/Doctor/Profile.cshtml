@model CareFleet.Models.Doctor
@{
    ViewData["Title"] = "Doctor Profile";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";

    var doctor = Model ?? new CareFleet.Models.Doctor {
        Id = 0,
        FirstName = ViewBag.FirstName?.ToString() ?? "Doctor",
        LastName  = ViewBag.LastName?.ToString()  ?? "User",
        Email     = ViewBag.UserEmail?.ToString()  ?? "doctor@carefleet.com",
        CreatedAt = DateTime.Now.AddYears(-2)
    };

    var initials = ((doctor.FirstName?.Length > 0 ? doctor.FirstName.Substring(0, 1) : "D") +
                   (doctor.LastName?.Length  > 0 ? doctor.LastName.Substring(0, 1)  : "R")).ToUpper();

    var memberSince = doctor.CreatedAt.ToString("MMMM yyyy");

    ViewBag.ActivePage  = "Profile";
    ViewBag.HideHeader  = true;
}

<div class="doctor-profile-page fade-in">

    <!-- ── Premium Header Card ──────────────────────────── -->
    <div class="premium-header-card mb-4">
        <div class="header-card-content">
            <div class="header-info">
                <!-- Breadcrumb -->
                <div class="header-breadcrumb mb-2">
                    <a href="@Url.Action("Dashboard","Doctor")"
                       class="text-white text-decoration-none opacity-75 hvr-opacity">Dashboard</a>
                    <i class="fas fa-chevron-right mx-2 small opacity-50 text-white"></i>
                    <span class="text-white fw-bold">My Profile</span>
                </div>

                <!-- Name + badges -->
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <div class="header-avatar-circle">@initials</div>
                    <div>
                        <h2 class="fw-800 text-white mb-2">
                            Dr. @doctor.FirstName @doctor.LastName
                        </h2>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="info-badge-light">
                                <i class="fas fa-id-card me-2"></i>DOC-@(doctor.Id.ToString("D4"))
                            </span>
                            @if (!string.IsNullOrEmpty(doctor.Specialization))
                            {
                                <span class="info-badge-light">
                                    <i class="fas fa-stethoscope me-2"></i>@doctor.Specialization
                                </span>
                            }
                            <span class="info-badge-light">
                                <i class="fas fa-check-circle me-2"></i>Verified
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="header-actions">
                <a href="@Url.Action("Settings","Doctor")" class="btn-premium-light">
                    <i class="fas fa-user-cog me-2"></i>Edit Profile
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- ── Main Content ──────────────────────────────────── -->
    <div class="row g-4 mt-1">

        <!-- Left Column — main info -->
        <div class="col-lg-8">

            <!-- Professional Overview Card -->
            <div class="premium-card mb-4 elevation-1">
                <div class="card-header-premium d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-hospital-user text-primary me-2"></i>Professional Overview
                    </h5>
                    <span class="badge bg-light text-primary border px-3 py-2 rounded-pill">
                        Active Physician
                    </span>
                </div>
                <div class="card-body-premium">
                    <div class="bio-section mb-4">
                        <h6 class="text-uppercase fw-800 text-secondary ls-1 mb-3">
                            Physician Profile Narrative
                        </h6>
                        <p class="text-secondary lh-lg mb-0 text-justify">
                            @(!string.IsNullOrEmpty(doctor.Specialization)
                                ? $"Dr. {doctor.FirstName} {doctor.LastName} is a specialist in {doctor.Specialization} " +
                                  $"serving patients through the CareFleet platform since {memberSince}. " +
                                  "Dedicated to delivering evidence-based, patient-centred care."
                                : "No professional profile description has been added yet. Complete your profile in " +
                                  "Account Settings to help patients and colleagues learn more about your expertise " +
                                  "and areas of practice.")
                        </p>
                    </div>
                </div>
            </div>

            <!-- Credential Stat Cards -->
            <div class="row g-4 mb-4">
                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-primary text-primary">
                            <i class="fas fa-stethoscope"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Specialization</span>
                            <span class="vital-value" style="font-size:0.82rem;">
                                @(string.IsNullOrEmpty(doctor.Specialization) ? "Not Set" : doctor.Specialization)
                            </span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-success text-success">
                            <i class="fas fa-certificate"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">License</span>
                            <span class="vital-value" style="font-size:0.82rem;">
                                @(string.IsNullOrEmpty(doctor.LicenseNumber) ? "N/A" : doctor.LicenseNumber)
                            </span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-info text-info">
                            <i class="fas fa-user-shield"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Account</span>
                            <span class="vital-value">Active</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-danger text-danger">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Since</span>
                            <span class="vital-value" style="font-size:0.82rem;">@doctor.CreatedAt.ToString("MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Career Timeline -->
            <div class="premium-card elevation-1">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-history text-primary me-2"></i>Career Journey
                    </h5>
                </div>
                <div class="card-body-premium p-0">
                    <div class="journey-timeline p-4">

                        <div class="journey-item">
                            <div class="journey-marker current"></div>
                            <div class="journey-content">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0">Practising on CareFleet</h6>
                                    <span class="journey-time">@DateTime.Now.ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    Actively managing appointments, medical records, and patient communications.
                                </p>
                            </div>
                        </div>

                        <div class="journey-item">
                            <div class="journey-marker"></div>
                            <div class="journey-content">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0">Profile Verified</h6>
                                    <span class="journey-time">@doctor.CreatedAt.AddDays(2).ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    Medical licence and credentials verified by the CareFleet administration.
                                </p>
                            </div>
                        </div>

                        <div class="journey-item">
                            <div class="journey-marker"></div>
                            <div class="journey-content">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0">Joined CareFleet</h6>
                                    <span class="journey-time">@doctor.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    Welcome to the future of digital healthcare management.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div><!-- /col-lg-8 -->

        <!-- Right Column -->
        <div class="col-lg-4">

            <!-- Contact Registry -->
            <div class="premium-card mb-4 elevation-1 sticky-card">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-address-book text-primary me-2"></i>Contact Registry
                    </h5>
                </div>
                <div class="card-body-premium">

                    <div class="registry-item mb-4">
                        <div class="registry-icon"><i class="fas fa-envelope-open-text"></i></div>
                        <div class="registry-detail">
                            <label>Official Email</label>
                            <p>@doctor.Email</p>
                        </div>
                    </div>

                    <div class="registry-item mb-4">
                        <div class="registry-icon"><i class="fas fa-phone-volume"></i></div>
                        <div class="registry-detail">
                            <label>Phone Line</label>
                            <p>@(string.IsNullOrEmpty(doctor.PhoneNumber) ? "Not Provided" : doctor.PhoneNumber)</p>
                        </div>
                    </div>

                    <div class="registry-item">
                        <div class="registry-icon"><i class="fas fa-id-badge"></i></div>
                        <div class="registry-detail">
                            <label>License Number</label>
                            <p>@(string.IsNullOrEmpty(doctor.LicenseNumber) ? "Not Set" : doctor.LicenseNumber)</p>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Quick Links -->
            <div class="premium-card mb-4 elevation-1">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-bolt text-primary me-2"></i>Quick Actions
                    </h5>
                </div>
                <div class="card-body-premium">
                    <div class="d-grid gap-2 text-white">
                        <a href="@Url.Action("Appointments","Doctor")"
                           class="btn btn-primary btn-premium-action py-3">
                            <i class="fas fa-calendar-check me-2"></i>View Appointments
                        </a>
                        <a href="@Url.Action("Patients","Doctor")"
                           class="btn btn-primary btn-premium-action py-3">
                            <i class="fas fa-users me-2"></i>My Patients
                        </a>
                        <a href="@Url.Action("MedicalRecords","Doctor")"
                           class="btn btn-primary btn-premium-action py-3">
                            <i class="fas fa-file-medical me-2"></i>Medical Records
                        </a>
                    </div>
                </div>
            </div>

            <!-- Activity Board -->
            <div class="premium-card elevation-1">
                <div class="card-header-premium bg-light-soft">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-chart-line text-primary me-2"></i>Activity Board
                    </h5>
                </div>
                <div class="card-body-premium p-0">
                    <div class="activity-grid">
                        <a href="@Url.Action("Appointments","Doctor")" class="activity-box">
                            <span class="activity-val">@(ViewBag.AppointmentCount ?? 0)</span>
                            <span class="activity-lab">Visits</span>
                        </a>
                        <a href="@Url.Action("Patients","Doctor")" class="activity-box border-start">
                            <span class="activity-val">@(ViewBag.PatientCount ?? 0)</span>
                            <span class="activity-lab">Patients</span>
                        </a>
                    </div>
                    <div class="activity-footer py-3 text-center border-top bg-light-v-soft">
                        <span class="text-secondary v-small fw-bold text-uppercase">
                            Member since @memberSince
                        </span>
                    </div>
                </div>
            </div>

        </div><!-- /col-lg-4 -->
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/patient-profile.css" asp-append-version="true" />
}
