@model IEnumerable<CareFleet.Models.Appointment>
@{
    ViewData["Title"] = "Doctor's Schedule";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewBag.ActivePage = "Appointments";
    ViewBag.HeaderTitle = "System Appointments";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/doctor-appointments.css" asp-append-version="true" />
}

<div class="premium-admin-container doctor-appointments-page mt-2">
    <!-- Premium Header Card (Admin Style) -->
    <div class="premium-header-card mb-4">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Clinical Schedule</h1>
                <p class="header-subtitle">
                    <i class="fas fa-user-md me-2"></i>
                    Track and manage your upcoming patient consultations
                </p>

                <div class="header-stats-container d-flex gap-3 mt-4">
                    <div class="glass-stat-badge">
                        <span class="stat-label">Total Appointments</span>
                        <span class="stat-value">@ViewBag.TotalAppointments</span>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <form method="get" asp-action="Appointments" id="dateFilterForm" class="d-flex align-items-center gap-3">
                    <input type="hidden" name="searchString" value="@ViewBag.CurrentFilter" />
                    <input type="hidden" name="statusFilter" value="@ViewBag.StatusFilter" />
                    <input type="hidden" name="dateFilter" id="dateFilterInput" value="@ViewBag.DateFilter" />
                    
                    <div class="filter-group-wrapper shadow-sm">
                        <button type="button" class="btn btn-sm filter-btn @(ViewBag.DateFilter == "All" || string.IsNullOrEmpty(ViewBag.DateFilter) ? "active" : "")" onclick="applyDateFilter('All')">All</button>
                        <button type="button" class="btn btn-sm filter-btn @(ViewBag.DateFilter == "Today" ? "active" : "")" onclick="applyDateFilter('Today')">Today</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Search & Filter Bar (Admin Style) -->
    <form method="get" asp-action="Appointments" id="filterForm">
        <input type="hidden" name="dateFilter" value="@ViewBag.DateFilter" />
        <div class="search-filter-section mb-4">
            <div class="search-input-wrapper flex-grow-1">
                <i class="fas fa-search"></i>
                <input type="text" name="searchString" id="appointmentSearch"
                       value="@ViewBag.CurrentFilter"
                       placeholder="Search patient records..."
                       class="premium-search-input">
            </div>
            <div class="filter-actions">
                <select name="statusFilter" id="statusFilter" class="btn-filter" style="outline: none; cursor: pointer; min-width: 150px;" onchange="this.form.submit()">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                    <option value="Confirmed" selected="@(ViewBag.StatusFilter == "Confirmed")">Confirmed</option>
                    <option value="Completed" selected="@(ViewBag.StatusFilter == "Completed")">Completed</option>
                    <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled")">Cancelled</option>
                </select>
                <a href="@Url.Action("Appointments")" class="btn-filter text-decoration-none">
                    <i class="fas fa-sync-alt"></i>
                </a>
            </div>
        </div>
    </form>

    <!-- Table Glass Wrapper (Admin Style) -->
    <div class="table-glass-wrapper shadow-lg overflow-visible">
        <table class="premium-table" id="appointmentsTable">
            <thead>
                <tr>
                    <th class="ps-5">Schedule</th>
                    <th>Patient Name</th>
                    <th>Reason</th>
                    <th class="text-center">Status</th>
                    <th class="text-center pe-5">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var initials = !string.IsNullOrEmpty(item.PatientName) ?
                        string.Join("", item.PatientName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(n => n[0])).ToUpper() : "PA";

                        <tr class="appointment-row" data-date="@item.AppointmentDate.ToString("MMM dd, yyyy")">
                            <td class="ps-5">
                                <div class="patient-info">
                                    <span class="patient-name">@item.AppointmentDate.ToString("MMM dd, yyyy")</span>
                                    <span class="patient-id text-primary"><i class="far fa-clock me-1"></i> @item.TimeSlot</span>
                                </div>
                            </td>
                            <td>
                                <div class="patient-identity">
                                    <div class="patient-avatar">
                                        @initials.Substring(0, Math.Min(2, initials.Length))
                                    </div>
                                    <div class="patient-info">
                                        <span class="patient-name">@item.PatientName</span>
                                        <span class="patient-id">ID: #AC-@item.Id.ToString("D4")</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="history-badge fw-600 truncate-text" title="@item.Reason">
                                    @(string.IsNullOrEmpty(item.Reason) ? "General Consultation" : item.Reason)
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="status-pill @item.Status.ToLower()">
                                    <i class="fas fa-circle small me-1 opacity-75"></i> @item.Status
                                </span>
                            </td>
                            <td class="pe-5">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <a href="@Url.Action("AppointmentDetails", "Doctor", new { id = item.Id })"
                                       class="btn-action-premium edit" title="Full Details">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <div class="dropdown">
                                        <button class="btn-action-premium view dropdown-toggle border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="fas fa-edit me-1"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2">
                                            <li class="px-3 py-2 dropdown-header small text-uppercase fw-800 text-muted">Quick Update</li>
                                            @foreach (var status in new[] { "Confirmed", "Completed", "Pending", "Cancelled" })
                                            {
                                                <li>
                                                    <form method="post" action="@Url.Action("UpdateAppointmentStatus", "Doctor")">
                                                        <input type="hidden" name="appointmentId" value="@item.Id" />
                                                        <input type="hidden" name="status" value="@status" />
                                                        <button type="submit" class="dropdown-item py-2 px-3 rounded-2 small fw-600 @(item.Status == status ? "text-primary bg-light" : "")">
                                                            Mark as @status
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            <li><hr class="dropdown-divider opacity-50"></li>
                                            <li>
                                                <a href="@Url.Action("Create", "Prescription", new { appointmentId = item.Id })" class="dropdown-item py-2 px-3 rounded-2 small fw-600 text-primary">
                                                    <i class="fas fa-file-medical me-2"></i> Issue Prescription
                                                </a>
                                            </li>
                                            <li>
                                                <a href="javascript:void(0)" onclick="createManualBill(@item.Id)" class="dropdown-item py-2 px-3 rounded-2 small fw-600 text-dark">
                                                    <i class="fas fa-file-invoice-dollar me-2"></i> Generate Bill
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 100px;">
                            <div class="empty-state">
                                <i class="fas fa-calendar-times mb-4" style="font-size: 4.5rem; color: #cbd5e1; opacity: 0.4;"></i>
                                <h3 style="color: #64748b; font-family: 'Outfit', sans-serif; font-weight: 700;">No Appointments Found</h3>
                                <p style="color: #94a3b8; font-weight: 500;">No clinical consultations match your current filter criteria.</p>
                                <a href="@Url.Action("Appointments")" class="btn btn-primary mt-3">Clear All Filters</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Premium Pagination -->
        @if (ViewBag.TotalAppointments > 0)
        {
            <div class="premium-pagination-container">
                <div class="pagination-info">
                    @{
                        int start = (ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1;
                        int end = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalAppointments);
                    }
                    Showing <span class="text-dark fw-bold">@start</span> to <span class="text-dark fw-bold">@end</span> of <span class="text-dark fw-bold">@ViewBag.TotalAppointments</span> appointments
                </div>
                
                <div class="pagination-controls">
                    <a href="@Url.Action("Appointments", new { page = ViewBag.CurrentPage - 1, searchString = ViewBag.CurrentFilter, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage <= 1 ? "disabled" : "")" title="Previous Page">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @if (ViewBag.TotalPages > 1)
                    {
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                            {
                                <a href="@Url.Action("Appointments", new { page = i, searchString = ViewBag.CurrentFilter, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                                   class="page-link-premium @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                            }
                            else if (i == ViewBag.CurrentPage - 3 || i == ViewBag.CurrentPage + 3)
                            {
                                <span class="px-2 text-muted">...</span>
                            }
                        }
                    }
                    else if (ViewBag.TotalPages == 1)
                    {
                        <a href="#" class="page-link-premium active">1</a>
                    }

                    <a href="@Url.Action("Appointments", new { page = ViewBag.CurrentPage + 1, searchString = ViewBag.CurrentFilter, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")" title="Next Page">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('appointmentSearch');
            const filterForm = document.getElementById('filterForm');
            
            let typingTimer;
            const doneTypingInterval = 800;

            searchInput?.addEventListener('keyup', function() {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => {
                    filterForm.submit();
                }, doneTypingInterval);
            });

            searchInput?.addEventListener('keydown', function() {
                clearTimeout(typingTimer);
            });
        });

        function applyDateFilter(filter) {
            document.getElementById('dateFilterInput').value = filter;
            document.getElementById('dateFilterForm').submit();
        }

        function createManualBill(appointmentId) {
            Swal.fire({
                title: 'Generate Invoice?',
                text: "This will create a standard consultation bill for this patient.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1B3C53',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Generate Bill'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Processing...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const formData = new FormData();
                    formData.append('appointmentId', appointmentId);
                    formData.append('__RequestVerificationToken', token);

                    fetch('@Url.Action("CreateAppointmentInvoice", "Billing")', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: 'Success!',
                                text: data.message,
                                icon: 'success',
                                confirmButtonColor: '#1B3C53'
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Notice', data.message, 'info');
                        }
                    })
                    .catch(error => {
                        Swal.fire('Error', 'An unexpected system error occurred.', 'error');
                    });
                }
            });
        }
    </script>
}
