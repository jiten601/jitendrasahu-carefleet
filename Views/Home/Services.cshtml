@{
    ViewData["Title"] = "Our Services";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true" />
}

<div class="fade-in">

    @* ===== HERO ===== *@
    <div class="services-hero container mt-3">
        <div class="row align-items-center position-relative z-3 px-lg-5 px-3 py-5">
            <div class="col-lg-8 mx-auto text-center">
                <div class="badge-premium mb-3 text-white">
                    <i class="fas fa-star me-2"></i>Our Solutions
                </div>
                <h1 class="hero-title-v2 mb-4">Comprehensive<br /><span style="color:#6ee7b7;">Medical Ecosystem</span></h1>
                <p class="hero-subtitle-v2 mx-auto" style="max-width:640px; opacity:0.9;">
                    CareFleet offers a wide array of digital tools to streamline clinical operations, improve patient care delivery, and optimize hospital management.
                </p>
                <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
                    <span class="services-hero-badge"><i class="fas fa-users me-2"></i>For Patients</span>
                    <span class="services-hero-badge"><i class="fas fa-user-doctor me-2"></i>For Doctors</span>
                    <span class="services-hero-badge"><i class="fas fa-building-columns me-2"></i>For Admins</span>
                </div>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    @* ===== SERVICES GRID ===== *@
    <div class="premium-section-wrapper">
        <div class="container" style="max-width:1100px;">

            <div class="text-center mb-5">
                <h2 class="fw-800" style="color:var(--primary-dark); font-family:'Outfit',sans-serif; font-size:2rem;">Everything Your Clinic Needs</h2>
                <p class="text-secondary mx-auto mt-2" style="max-width:580px;">Six powerful modules, one unified platform — designed to work seamlessly together.</p>
            </div>

            <div class="row g-4 mb-5">

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#4f86c6;">
                            <div class="service-icon"><i class="fas fa-calendar-check"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Smart Scheduling</h4>
                            <p class="service-desc">AI-powered appointment management that reduces wait times and synchronizes clinical workflows for doctors and patients in real-time.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> Conflict detection</li>
                                <li><i class="fas fa-check-circle"></i> Automated reminders</li>
                                <li><i class="fas fa-check-circle"></i> Real-time sync</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#5cb85c;">
                            <div class="service-icon"><i class="fas fa-laptop-medical"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Electronic Health Records</h4>
                            <p class="service-desc">Secure, digital storage for patient history, prescriptions, and test results, instantly accessible for better clinical assessment.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> AES-256 encrypted</li>
                                <li><i class="fas fa-check-circle"></i> Full history timeline</li>
                                <li><i class="fas fa-check-circle"></i> Lab result integration</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#9b59b6;">
                            <div class="service-icon"><i class="fas fa-video"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Virtual Consultations</h4>
                            <p class="service-desc">Built-in high-definition video conferencing and secure messaging allowing medical professionals to treat patients remotely.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> HD video calls</li>
                                <li><i class="fas fa-check-circle"></i> Secure messaging</li>
                                <li><i class="fas fa-check-circle"></i> File sharing</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#e67e22;">
                            <div class="service-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Medical Billing</h4>
                            <p class="service-desc">Transparent, automated invoicing and integrated payment processing for patients, reducing administrative overhead and billing errors.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> Auto-generated invoices</li>
                                <li><i class="fas fa-check-circle"></i> PCI-DSS compliant</li>
                                <li><i class="fas fa-check-circle"></i> PDF export</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#e74c3c;">
                            <div class="service-icon"><i class="fas fa-bell"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Dynamic Notifications</h4>
                            <p class="service-desc">Automatic notification system for check-ups, follow-up alerts, and prescription reminders, keeping patients engaged throughout care.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> Smart alerts</li>
                                <li><i class="fas fa-check-circle"></i> Prescription reminders</li>
                                <li><i class="fas fa-check-circle"></i> Follow-up tracking</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="service-card">
                        <div class="service-card-top" style="--clr:#1abc9c;">
                            <div class="service-icon"><i class="fas fa-hospital"></i></div>
                        </div>
                        <div class="service-card-body">
                            <h4 class="service-title">Admin Infrastructure</h4>
                            <p class="service-desc">Comprehensive hospital-grade infrastructure for managing staff, clinical departments, and facility analytics from a single dashboard.</p>
                            <ul class="service-features">
                                <li><i class="fas fa-check-circle"></i> Staff management</li>
                                <li><i class="fas fa-check-circle"></i> Analytics dashboard</li>
                                <li><i class="fas fa-check-circle"></i> Role-based access</li>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>


        </div>
    </div>

        @* ===== CTA BANNER ===== *@
    <div class="container" style="max-width:1100px;">
        <div class="services-cta-card">
            <div class="row align-items-center">
                <div class="col-lg-8 mb-4 mb-lg-0">
                    <h3 class="services-cta-title">Ready to Transform Your Practice?</h3>
                    <p class="services-cta-sub">Join thousands of healthcare professionals already using CareFleet to deliver better, faster, and safer care.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 py-3 fw-700 rounded-pill" style="color:var(--primary-dark);">
                        <i class="fas fa-rocket me-2"></i>Get Started Free
                    </a>
                </div>
            </div>
            <div class="header-bg-pattern"></div>
        </div>
    </div>
</div>
