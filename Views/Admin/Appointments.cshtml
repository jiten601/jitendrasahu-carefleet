@model IEnumerable<CareFleet.Models.Appointment>
@{
    ViewData["Title"] = "Appointments Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Appointments";
    ViewBag.HeaderTitle = "System Appointments";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-appointments.css" asp-append-version="true" />
}

<div class="premium-admin-container">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">System Appointments</h1>
                <p class="header-subtitle">
                    <i class="fas fa-calendar-check me-2"></i>
                    Manage and track all medical appointments in the system
                </p>

                <div style="margin-top: 30px !important;" class="d-flex gap-3">
                    <div class="glass-stat-badge">
                        <span class="stat-label">Total Appointments</span>
                        <span class="stat-value">@ViewBag.TotalAppointments</span>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <form method="get" asp-action="Appointments" id="dateFilterForm" class="d-flex align-items-center gap-3">
                    <input type="hidden" name="searchTerm" value="@ViewBag.SearchTerm" />
                    <input type="hidden" name="statusFilter" value="@ViewBag.StatusFilter" />
                    <input type="hidden" name="dateFilter" id="dateFilterInput" value="@ViewBag.DateFilter" />
                    
                    <div class="filter-group-wrapper shadow-sm">
                        <button type="button" class="btn btn-sm filter-btn @(ViewBag.DateFilter == "All" || string.IsNullOrEmpty(ViewBag.DateFilter) ? "active" : "")" onclick="applyDateFilter('All')">All</button>
                        <button type="button" class="btn btn-sm filter-btn @(ViewBag.DateFilter == "Today" ? "active" : "")" onclick="applyDateFilter('Today')">Today</button>
                    </div>
                    <a href="@Url.Action("Book", "Appointment")" class="btn-premium-light text-decoration-none">
                        <i class="fas fa-plus-circle me-2"></i> Book Appointment
                    </a>
                </form>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Search & Filter Bar -->
    <form method="get" asp-action="Appointments" id="filterForm">
        <input type="hidden" name="dateFilter" value="@ViewBag.DateFilter" />
        <div class="search-filter-section">
            <div class="search-input-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" id="appointmentSearch" placeholder="Search by patient, doctor, or reason..." class="premium-search-input">
            </div>
            <div class="filter-actions">
                <select name="statusFilter" id="statusFilter" class="btn-filter" style="outline: none; cursor: pointer;" onchange="this.form.submit()">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                    <option value="Confirmed" selected="@(ViewBag.StatusFilter == "Confirmed")">Confirmed</option>
                    <option value="Completed" selected="@(ViewBag.StatusFilter == "Completed")">Completed</option>
                    <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled")">Cancelled</option>
                </select>
                <a href="@Url.Action("Appointments")" class="btn-filter text-decoration-none" title="Reset Filters">
                    <i class="fas fa-sync-alt"></i>
                </a>
            </div>
        </div>
    </form>

    <div class="table-glass-wrapper">
        <table class="premium-table" id="appointmentsTable">
            <thead>
                <tr>
                    <th>Schedule</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Fee</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var appointment in Model)
                    {
                        var patientInitials = !string.IsNullOrEmpty(appointment.PatientName) ?
                        string.Join("", appointment.PatientName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(n => n[0])).ToUpper() : "P";
                        var doctorInitials = !string.IsNullOrEmpty(appointment.DoctorName) ?
                        string.Join("", appointment.DoctorName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(n => n[0])).ToUpper() : "D";

                        <tr data-status="@appointment.Status">
                            <td>
                                <div class="patient-info">
                                    <span class="patient-name">@appointment.AppointmentDate.ToString("MMM dd, yyyy")</span>
                                    <span class="patient-id text-primary"><i class="far fa-clock me-1"></i> @appointment.TimeSlot</span>
                                </div>
                            </td>
                            <td>
                                <div class="patient-identity">
                                    <div class="patient-avatar">@patientInitials.Substring(0, Math.Min(2, patientInitials.Length))</div>
                                    <div class="patient-info">
                                        <span class="patient-name">@appointment.PatientName</span>
                                    </div>
                                </div>
                            </td>
                             <td>
                                <div class="patient-identity">
                                    <div class="doctor-avatar">@doctorInitials.Substring(0, Math.Min(2, doctorInitials.Length))</div>
                                    <div class="patient-info">
                                        <span class="patient-name">@appointment.DoctorName</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold" style="color: #4361ee;">Rs. @appointment.Fee.ToString("N0")</span>
                            </td>
                            <td>
                                <span class="history-badge" title="@appointment.Reason">
                                    @(string.IsNullOrEmpty(appointment.Reason) ? "General Checkup" : appointment.Reason)
                                </span>
                            </td>
                            <td>
                                <span class="status-pill @appointment.Status.ToLower()">@appointment.Status</span>
                            </td>
                            <td>
                                <div class="premium-action-group">
                                    @if (appointment.Status == "Pending")
                                    {
                                        <form asp-action="ConfirmAppointment" asp-controller="Admin" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appointment.Id" />
                                            <button type="submit" class="btn-action-premium view" title="Confirm Appointment">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    <a href="@Url.Action("AppointmentDetails", "Admin", new { id = appointment.Id })" class="btn-action-premium edit" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (appointment.Status != "Cancelled")
                                    {
                                        <form asp-action="CancelAppointment" asp-controller="Admin" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appointment.Id" />
                                            <button type="submit" class="btn-action-premium cancel" title="Cancel Appointment">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="DeleteAppointment" asp-controller="Admin" method="post" style="display: inline;" onsubmit="return confirm('Permanently delete this record?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appointment.Id" />
                                        <button type="submit" class="btn-action-premium delete" title="Permanently Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 80px;">
                            <div class="empty-state">
                                <i class="fas fa-calendar-times mb-4" style="font-size: 4rem; color: #cbd5e1; opacity: 0.5;"></i>
                                <h3 style="color: #64748b; font-family: 'Outfit', sans-serif;">No appointments found</h3>
                                <p style="color: #94a3b8;">There are no appointments matching your criteria.</p>
                                <a href="@Url.Action("Appointments")" class="btn btn-primary mt-3">Clear Filters</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Premium Pagination -->
        @if (ViewBag.TotalItems > 0)
        {
            <div class="premium-pagination-container">
                <div class="pagination-info">
                    @{
                        int start = (ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1;
                        int end = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems);
                    }
                    Showing <span class="text-dark fw-bold">@start</span> to <span class="text-dark fw-bold">@end</span> of <span class="text-dark fw-bold">@ViewBag.TotalItems</span> appointments
                </div>
                
                <div class="pagination-controls">
                    <a href="@Url.Action("Appointments", new { page = ViewBag.CurrentPage - 1, searchTerm = ViewBag.SearchTerm, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage <= 1 ? "disabled" : "")" title="Previous Page">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @if (ViewBag.TotalPages > 1)
                    {
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                            {
                                <a href="@Url.Action("Appointments", new { page = i, searchTerm = ViewBag.SearchTerm, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                                   class="page-link-premium @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                            }
                            else if (i == ViewBag.CurrentPage - 3 || i == ViewBag.CurrentPage + 3)
                            {
                                <span class="px-2 text-muted">...</span>
                            }
                        }
                    }
                    else if (ViewBag.TotalPages == 1)
                    {
                        <a href="#" class="page-link-premium active">1</a>
                    }

                    <a href="@Url.Action("Appointments", new { page = ViewBag.CurrentPage + 1, searchTerm = ViewBag.SearchTerm, statusFilter = ViewBag.StatusFilter, dateFilter = ViewBag.DateFilter })" 
                       class="page-link-premium @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")" title="Next Page">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('appointmentSearch');
            const filterForm = document.getElementById('filterForm');
            
            let typingTimer;
            const doneTypingInterval = 800;

            searchInput?.addEventListener('keyup', function() {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => {
                    filterForm.submit();
                }, doneTypingInterval);
            });

            searchInput?.addEventListener('keydown', function() {
                clearTimeout(typingTimer);
            });
        });

        function applyDateFilter(filter) {
            document.getElementById('dateFilterInput').value = filter;
            document.getElementById('dateFilterForm').submit();
        }
    </script>
}
