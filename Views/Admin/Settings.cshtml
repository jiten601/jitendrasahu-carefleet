@model CareFleet.Models.ApplicationUser
@{
    ViewData["Title"] = "Admin Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var user = Model ?? new CareFleet.Models.ApplicationUser
    {
        Id = 0,
        FirstName = ViewBag.FirstName?.ToString() ?? "Admin",
        LastName = ViewBag.LastName?.ToString() ?? "User",
        Email = ViewBag.UserEmail?.ToString() ?? "admin@carefleet.com"
    };

    var initials = ((user.FirstName?.Length > 0 ? user.FirstName.Substring(0, 1) : "A") +
                   (user.LastName?.Length > 0 ? user.LastName.Substring(0, 1) : "D")).ToUpper();

    ViewBag.ActivePage = "Settings";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-settings.css" asp-append-version="true" />
}

<div class="admin-settings-page fade-in py-5">

    <!-- Premium Header -->
    <div class="premium-header-card mb-5">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-bold text-white mb-2">Account Settings</h1>
                <p class="text-white-50 mb-0">Manage your profile and system security preferences</p>
            </div>
            <div class="header-actions">
                <div class="profile-badge-premium">
                    <div class="avatar-circle">@initials</div>
                    <div class="badge-text text-white">
                        <span class="d-block fw-bold">@user.FirstName @user.LastName</span>
                        <span class="d-block small text-white-50">Administrator</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="row g-5 d-flex justify-content-center">
        <div class="col-lg-8">

            <!-- Tabs -->
            <form method="post" action="@Url.Action("Profile", "Admin")" id="settingsForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@user.Id" />
                <input type="hidden" name="Email" value="@user.Email" />
                <input type="hidden" name="Role" value="@user.Role" />
                <input type="hidden" name="PasswordHash" value="@user.PasswordHash" />

                <!-- Single Profile Section (No Tabs) -->
                <div class="premium-card">
                    <div class="card-header-premium">
                        <h5 class="fw-bold mb-0">
                            <i class="fas fa-user-edit me-2"></i>Personal Profile Information
                        </h5>
                    </div>
                    <div class="card-body-premium">
                        <h6 class="settings-section-title">Identity Details</h6>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="form-label">
                                        <i class="fas fa-user"></i> First Name
                                    </label>
                                    <input type="text" class="form-control" name="FirstName" value="@user.FirstName" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="form-label">
                                        <i class="fas fa-user"></i> Last Name
                                    </label>
                                    <input type="text" class="form-control" name="LastName" value="@user.LastName" required>
                                </div>
                            </div>
                            <div class="col-12 mt-2">
                                <div class="form-group mb-0">
                                    <label class="form-label">
                                        <i class="fas fa-envelope"></i> Email Address <span class="text-muted ms-2">(Read-only)</span>
                                    </label>
                                    <input type="email" class="form-control"
                                           style="background-color: #f8fafc; cursor: not-allowed;"
                                           value="@user.Email"
                                           readonly disabled><br></br>
                                    <p class="text-muted small mt-4 mb-0">
                                        <i class="fas fa-info-circle me-1"></i> Email address is used for system identity and cannot be changed here.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Buttons -->
                <div class="d-flex justify-content-center gap-4 mt-5 pt-4">
                    <button type="submit" class="btn-primary-small"
                            style="padding: 16px 50px; font-size: 16px;">
                        <i class="fas fa-check-circle me-2"></i> Save Changes
                    </button>

                    <button type="reset" class="btn-primary-small"
                            style="background: #f1f5f9; color: #475569;
                                   padding: 16px 50px; font-size: 16px;
                                   border: 1px solid #e2e8f0; box-shadow: none;">
                        Reset Form
                    </button>
                </div>
            </form>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('.nav-link-premium');
            const contents = document.querySelectorAll('.tab-pane-premium');

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const target = tab.getAttribute('data-tab');

                    tabs.forEach(t => t.classList.remove('active'));
                    contents.forEach(c => c.classList.remove('active'));

                    tab.classList.add('active');
                    document.querySelector(`.tab-pane-premium[data-content="${target}"]`)
                        .classList.add('active');
                });
            });
        });
    </script>
}