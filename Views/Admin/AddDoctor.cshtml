@model CareFleet.Models.Doctor
@{
    ViewData["Title"] = "Add New Doctor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Doctors";
    ViewBag.HeaderTitle = "System Administration";
    ViewBag.HideHeader = true;
}

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" />
    <link rel="stylesheet" href="~/css/admin-premium-forms.css" />
}

<div class="premium-admin-container">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Register New Doctor</h1>
                <p class="header-subtitle"><i class="fas fa-user-plus me-2"></i> Add a healthcare professional to the CareFleet medical network</p>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Doctors", "Admin")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-arrow-left me-2"></i> Back to Doctors List
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="premium-form-container">
        <div class="premium-glass-card">
            <h2 class="form-section-title">
                <i class="fas fa-stethoscope text-primary"></i> Medical Practitioner Registration
            </h2>

            <form asp-action="AddDoctor" method="post">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="FirstName">First Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-user-md"></i>
                            <input asp-for="FirstName" class="premium-input" placeholder="e.g. Ram" required />
                        </div>
                        <span asp-validation-for="FirstName" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="LastName">Last Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-user-tag"></i>
                            <input asp-for="LastName" class="premium-input" placeholder="e.g. Bista" required />
                        </div>
                        <span asp-validation-for="LastName" class="validation-message"></span>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Email">Email Address</label>
                        <div class="input-group-premium">
                            <i class="fas fa-envelope"></i>
                            <input asp-for="Email" type="email" class="premium-input" placeholder="doctor@carefleet.com" required />
                        </div>
                        <span asp-validation-for="Email" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="PhoneNumber">Contact Number</label>
                        <div class="input-group-premium">
                            <i class="fas fa-phone"></i>
                            <input asp-for="PhoneNumber" class="premium-input" placeholder="+977 98000-0000" required />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="validation-message"></span>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Specialization">Medical Specialization</label>
                        <div class="input-group-premium">
                            <i class="fas fa-briefcase-medical"></i>
                            <select asp-for="Specialization" class="premium-input" required>
                                <option value="">Select Field...</option>
                                <option value="Cardiology">Cardiology</option>
                                <option value="Dermatology">Dermatology</option>
                                <option value="Neurology">Neurology</option>
                                <option value="Pediatrics">Pediatrics</option>
                                <option value="General Medicine">General Medicine</option>
                                <option value="Orthopedics">Orthopedics</option>
                                <option value="Gastroenterology">Gastroenterology</option>
                                <option value="Oncology">Oncology</option>
                                <option value="Psychiatry">Psychiatry</option>
                            </select>
                        </div>
                        <span asp-validation-for="Specialization" class="validation-message"></span>
                    </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="LicenseNumber">Government License No.</label>
                        <div class="input-group-premium">
                            <i class="fas fa-id-card"></i>
                            <input asp-for="LicenseNumber" class="premium-input" placeholder="e.g. LIC-123456" required />
                        </div>
                        <span asp-validation-for="LicenseNumber" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label">Account Password</label>
                        <div class="input-group-premium">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="password" class="premium-input" placeholder="Set temporary password" required />
                        </div>
                        @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                        {
                            <span class="text-danger small">@ViewData.ModelState["Password"].Errors[0].ErrorMessage</span>
                        }
                    </div>
                </div>

                <div class="form-actions-premium">
                    <button type="submit" class="btn-premium-save">
                        <i class="fas fa-plus-circle"></i> Register Doctor
                    </button>
                    <button type="reset" class="btn-premium-cancel">
                        Reset Form
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Specific page adjustments if needed */
    .premium-form-container {
        max-width: 900px;
        margin-top: -15px;
    }
</style>
