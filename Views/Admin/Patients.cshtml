@model IEnumerable<CareFleet.Models.Patient>
@{
    ViewData["Title"] = "Patients Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Patients";
    ViewBag.HeaderTitle = "Patients Management";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" asp-append-version="true" />
}

<div class="premium-admin-container">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Patients Management</h1>
                <p class="header-subtitle"><i class="fas fa-heartbeat me-2"></i> Manage and monitor all registered patients in the system</p>
                
                <div style="margin-top: 30px !important;" class="d-flex gap-3">
                    <div class="glass-stat-badge">
                        <span class="stat-label">Total Patients</span>
                        <span class="stat-value">@ViewBag.TotalPatients</span>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Create", "Patient")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-plus-circle me-2"></i> Add New Patient
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Search & Filter Bar -->
    <form method="get" asp-action="Patients" id="filterForm">
        <div class="search-filter-section">
            <div class="search-input-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" id="patientSearch" placeholder="Search by name, ID, or email..." class="premium-search-input">
            </div>
            <div class="filter-actions">
                <a href="@Url.Action("Patients")" class="btn-filter text-decoration-none" title="Reset Filters">
                    <i class="fas fa-sync-alt"></i> Refresh Data
                </a>
            </div>
        </div>
    </form>

    <div class="table-glass-wrapper">
        <table class="premium-table" id="patientsTable">
            <thead>
                <tr>
                    <th>Patient Details</th>
                    <th>Age / Gender</th>
                    <th>Contact Info</th>
                    <th>Medical History</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var patient in Model)
                    {
                        var initials = "";
                        if (!string.IsNullOrEmpty(patient.FirstName) && !string.IsNullOrEmpty(patient.LastName))
                        {
                            initials = (patient.FirstName.Substring(0, 1) + patient.LastName.Substring(0, 1)).ToUpper();
                        }
                        else if (!string.IsNullOrEmpty(patient.FirstName))
                        {
                            initials = patient.FirstName.Substring(0, Math.Min(2, patient.FirstName.Length)).ToUpper();
                        }
                        else
                        {
                            initials = "P";
                        }

                        <tr>
                            <td>
                                <div class="patient-identity">
                                    <div class="patient-avatar">@initials</div>
                                    <div class="patient-info">
                                        <span class="patient-name">@patient.FirstName @patient.LastName</span>
                                        <span class="patient-id">PAT-ID: @patient.Id.ToString("D5")</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="data-label">@(DateTime.Now.Year - (patient.DateOfBirth.Year)) Yrs</span>
                                <span class="data-sublabel">@patient.Gender</span>
                            </td>
                            <td>
                                <div class="email-pill" title="@patient.Email">
                                    <i class="far fa-envelope me-2"></i> @patient.Email
                                </div>
                                <span class="data-sublabel mt-2"><i class="fas fa-phone"></i> @patient.PhoneNumber</span>
                            </td>
                            <td>
                                <span class="history-badge" title="@patient.MedicalHistory">
                                    @(string.IsNullOrEmpty(patient.MedicalHistory) ? "Normal" : patient.MedicalHistory)
                                </span>
                            </td>
                            <td>
                                <span class="status-pill active">Registered</span>
                            </td>
                            <td>
                                <div class="premium-action-group">
                                    <a href="@Url.Action("Edit", "Patient", new { id = patient.Id })" class="btn-action-premium edit" title="Edit Patient">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <form asp-action="Delete" asp-controller="Patient" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this patient?');">
                                        <input type="hidden" name="id" value="@patient.Id" />
                                        <button type="submit" class="btn-action-premium delete" title="Delete Patient">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 80px;">
                            <div class="empty-state">
                                <i class="fas fa-folder-open mb-4" style="font-size: 4rem; color: #cbd5e1; opacity: 0.5;"></i>
                                <h3 style="color: #64748b; font-family: 'Outfit', sans-serif;">No patients found</h3>
                                <p style="color: #94a3b8;">There are no patients matching your criteria.</p>
                                <a href="@Url.Action("Patients")" class="btn btn-primary mt-3">Clear Filters</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Premium Pagination -->
        @if (ViewBag.TotalItems > 0)
        {
            <div class="premium-pagination-container">
                <div class="pagination-info">
                    @{
                        int start = (ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1;
                        int end = Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems);
                    }
                    Showing <span class="text-dark fw-bold">@start</span> to <span class="text-dark fw-bold">@end</span> of <span class="text-dark fw-bold">@ViewBag.TotalItems</span> patients
                </div>
                
                <div class="pagination-controls">
                    <a href="@Url.Action("Patients", new { page = ViewBag.CurrentPage - 1, searchTerm = ViewBag.SearchTerm })" 
                       class="page-link-premium @(ViewBag.CurrentPage <= 1 ? "disabled" : "")" title="Previous Page">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @if (ViewBag.TotalPages > 1)
                    {
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 2 && i <= ViewBag.CurrentPage + 2))
                            {
                                <a href="@Url.Action("Patients", new { page = i, searchTerm = ViewBag.SearchTerm })" 
                                   class="page-link-premium @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                            }
                            else if (i == ViewBag.CurrentPage - 3 || i == ViewBag.CurrentPage + 3)
                            {
                                <span class="px-2 text-muted">...</span>
                            }
                        }
                    }
                    else if (ViewBag.TotalPages == 1)
                    {
                        <a href="#" class="page-link-premium active">1</a>
                    }

                    <a href="@Url.Action("Patients", new { page = ViewBag.CurrentPage + 1, searchTerm = ViewBag.SearchTerm })" 
                       class="page-link-premium @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")" title="Next Page">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('patientSearch');
            const filterForm = document.getElementById('filterForm');
            
            let typingTimer;
            const doneTypingInterval = 800;

            searchInput?.addEventListener('keyup', function() {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => {
                    filterForm.submit();
                }, doneTypingInterval);
            });

            searchInput?.addEventListener('keydown', function() {
                clearTimeout(typingTimer);
            });
        });
    </script>
}
