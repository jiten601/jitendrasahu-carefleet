@model CareFleet.Models.ApplicationUser
@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Users";
    ViewBag.HeaderTitle = "System Administration";
    ViewBag.HideHeader = true;
}

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" />
    <link rel="stylesheet" href="~/css/admin-premium-forms.css" />
}

<div class="premium-admin-container">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">Edit User Profile</h1>
                <p class="header-subtitle"><i class="fas fa-user-edit me-2"></i> Modify system permissions and account details for @Model.FirstName @Model.LastName</p>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Users", "Admin")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-arrow-left me-2"></i> Back to User List
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="premium-form-container">
        <div class="premium-glass-card">
            <h2 class="form-section-title">
                <i class="fas fa-id-card text-primary"></i> Account Information
            </h2>

            <form asp-action="EditUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="FirstName">First Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-user"></i>
                            <input asp-for="FirstName" class="premium-input" placeholder="e.g. John" required />
                        </div>
                        <span asp-validation-for="FirstName" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="LastName">Last Name</label>
                        <div class="input-group-premium">
                            <i class="fas fa-user-tag"></i>
                            <input asp-for="LastName" class="premium-input" placeholder="e.g. Doe" required />
                        </div>
                        <span asp-validation-for="LastName" class="validation-message"></span>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Email">Email Address</label>
                        <div class="input-group-premium">
                            <i class="fas fa-envelope"></i>
                            <input asp-for="Email" type="email" class="premium-input" placeholder="e.g. john.doe@example.com" required />
                        </div>
                        <span asp-validation-for="Email" class="validation-message"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="premium-label" asp-for="Role">Assign User Role</label>
                        <div class="input-group-premium">
                            <i class="fas fa-shield-alt"></i>
                            <select asp-for="Role" class="premium-input" required>
                                <option value="Admin">Administrator</option>
                                <option value="Doctor">Doctor</option>
                                <option value="Patient">Standard Patient</option>
                            </select>
                        </div>
                        <span asp-validation-for="Role" class="validation-message"></span>
                    </div>
                </div>

                <div class="form-actions-premium">
                    <button type="submit" class="btn-premium-save">
                        <i class="fas fa-save"></i> Save User Changes
                    </button>
                    <a href="@Url.Action("Users", "Admin")" class="btn-premium-cancel">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Specific page adjustments if needed */
    .premium-form-container {
        max-width: 850px;
        margin-top: -15px;
    }
</style>
