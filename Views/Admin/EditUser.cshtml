@model CareFleet.Models.ApplicationUser
@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Users";
    ViewBag.HeaderTitle = "System Administration";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
}

<div class="fade-in">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-bold text-white mb-2">Edit User</h1>
                <p class="text-white-50 mb-0">Modify details for user: @Model.FirstName @Model.LastName</p>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Users", "Admin")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>


<div class="form-container">
    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="FirstName">
                    <i class="fas fa-user"></i> First Name
                </label>
                <input asp-for="FirstName" class="form-control" required />
                <span asp-validation-for="FirstName" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LastName">
                    <i class="fas fa-user"></i> Last Name
                </label>
                <input asp-for="LastName" class="form-control" required />
                <span asp-validation-for="LastName" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="Email">
                    <i class="fas fa-envelope"></i> Email Address
                </label>
                <input asp-for="Email" type="email" class="form-control" required />
                <span asp-validation-for="Email" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Role">
                    <i class="fas fa-user-shield"></i> User Role
                </label>
                <select asp-for="Role" class="form-control" required>
                    <option value="Admin">Admin</option>
                    <option value="Doctor">Doctor</option>
                    <option value="Patient">Patient</option>
                </select>
                <span asp-validation-for="Role" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div style="margin-top: 40px; display: flex; gap: 20px;">
            <button type="submit" class="btn-primary-small fw-bold" style="padding: 14px 40px; font-size: 16px;">
                <i class="fas fa-save"></i> Save Changes
            </button>
            <a href="@Url.Action("Users", "Admin")" class="btn-primary-small" style="background: #f1f5f9; color: #475569; padding: 14px 40px; font-size: 16px; border: 1px solid #e2e8f0; box-shadow: none; text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">
                Cancel
            </a>
        </div>
    </form>
</div>
</div>
