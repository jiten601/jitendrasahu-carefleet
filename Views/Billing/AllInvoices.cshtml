@model IEnumerable<CareFleet.Models.Invoice>
@{
    ViewData["Title"] = "Financial Command Center";
    var userRole = Context.Session.GetString("UserRole");
    Layout = userRole == "Admin" ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_DoctorLayout.cshtml";
    ViewBag.ActivePage = "Billing";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
}

<div class="container-fluid px-md-6 py-2 fade-in">
    <!-- Premium Header -->
    <div class="premium-header-card mb-5">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-800 text-white mb-2">Financial Operations</h1>
                <p class="text-white opacity-75 mb-0">Enterprise ledger management and live revenue analytics.</p>
            </div>
            <div class="header-actions">
                <div class="d-flex align-items-center gap-3">
                    <div class="search-box-modern">
                        <i class="fas fa-search"></i>
                        <input type="text" id="invoiceSearch" placeholder="Search ledger..." onkeyup="filterInvoices()">
                    </div>
                    <button class="btn-premium-light shadow-sm" onclick="window.print()">
                        <i class="fas fa-file-pdf me-2"></i>Generate Statement
                    </button>
                </div>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Live Performance Metrics -->
    <div class="row g-4 mb-5">
        <div class="col-lg-3 col-md-6">
            <div class="billing-stats-card bg-white p-4 h-100 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="header-icon-box bg-light text-primary">
                        <i class="fas fa-globe"></i>
                    </div>
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 x-small fw-800">Gross Vol.</span>
                </div>
                <h3 class="fw-900 mb-1">Rs @Model.Sum(i => i.TotalAmount).ToString("N0")</h3>
                <p class="text-muted v-small fw-800 text-uppercase ls-1 mb-0">Aggregate Revenue Lifecycle</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="billing-stats-card bg-white p-4 h-100 shadow-sm border-0 border-bottom border-success border-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="header-icon-box bg-success-subtle text-success">
                        <i class="fas fa-check-double"></i>
                    </div>
                    <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 x-small fw-800">Settled</span>
                </div>
                <h3 class="fw-900 mb-1 text-success">Rs @Model.Where(i => i.Status == "Paid").Sum(i => i.TotalAmount).ToString("N0")</h3>
                <p class="text-muted v-small fw-800 text-uppercase ls-1 mb-0">Realized Net Income</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="billing-stats-card bg-white p-4 h-100 shadow-sm border-0 border-bottom border-danger border-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="header-icon-box bg-danger-subtle text-danger">
                        <i class="fas fa-hourglass-start"></i>
                    </div>
                    <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-1 x-small fw-800">Awaiting</span>
                </div>
                <h3 class="fw-900 mb-1 text-danger">Rs @Model.Where(i => i.Status != "Paid").Sum(i => i.TotalAmount).ToString("N0")</h3>
                <p class="text-muted v-small fw-800 text-uppercase ls-1 mb-0">Pending Receivables</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="billing-stats-card bg-white p-4 h-100 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="header-icon-box bg-warning-subtle text-warning">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-1 x-small fw-800">Compliance</span>
                </div>
                <h3 class="fw-900 mb-1">@Model.Count()</h3>
                <p class="text-muted v-small fw-800 text-uppercase ls-1 mb-0">Total Verified Entries</p>
            </div>
        </div>
    </div>

    <!-- Tabs for Filtering -->
    <div class="d-flex align-items-center mb-4 gap-3 bg-white p-2 rounded-4 shadow-sm border" style="width: fit-content;">
        <button class="btn btn-premium-tab active" onclick="applyStatusFilter('all', this)">
            <i class="fas fa-list-ul me-2"></i>All Activity
        </button>
        <button class="btn btn-premium-tab" onclick="applyStatusFilter('Paid', this)">
            <i class="fas fa-check-circle me-2"></i>Cleared
        </button>
        <button class="btn btn-premium-tab" onclick="applyStatusFilter('Unpaid', this)">
            <i class="fas fa-clock me-2"></i>Awaiting
        </button>
        <button class="btn btn-premium-tab" onclick="applyStatusFilter('Partially Paid', this)">
            <i class="fas fa-exclamation-circle me-2"></i>Partial
        </button>
    </div>

        <div class="ledger-cards-container" id="ledgerContainer">
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    var statusAccent = item.Status == "Paid" ? "accent-paid" : (item.Status == "Unpaid" ? "accent-unpaid" : "accent-partial");
                    
                    <div class="ledger-row-card fade-in" data-status="@item.Status">
                        <div class="card-accent-bar @statusAccent"></div>
                        
                        <div class="ledger-patient-vcard">
                            @{
                                var initials = (item.Patient?.FirstName?.FirstOrDefault().ToString() ?? "") + (item.Patient?.LastName?.FirstOrDefault().ToString() ?? "");
                                if (string.IsNullOrEmpty(initials)) initials = "?";
                            }
                            <div class="vcard-avatar">@initials</div>
                            <div>
                                <h5 class="fw-900 mb-1 text-dark patient-name fs-5">@item.Patient?.FirstName @item.Patient?.LastName</h5>
                                <p class="text-muted v-small mb-0 fw-800 text-uppercase ls-1">Reference: <span class="text-primary invoice-ref">#INV-@item.Id.ToString("D6")</span></p>
                            </div>
                        </div>

                        <div class="ledger-data-section">
                            <div class="data-item">
                                <span class="data-label">Appointment</span>
                                <span class="data-value">#APPT-@item.AppointmentId</span>
                            </div>
                            <div class="data-item">
                                <span class="data-label">Issued On</span>
                                <span class="data-value fw-700">@item.DateGenerated.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="data-item text-end" style="min-width: 140px;">
                                <span class="data-label">Status</span>
                                @{
                                    var badgeClass = item.Status == "Paid" ? "status-paid" : (item.Status == "Unpaid" ? "status-unpaid" : "status-partially-paid");
                                }
                                <div class="d-flex justify-content-end">
                                    <span class="payment-status-badge @badgeClass">@item.Status</span>
                                </div>
                            </div>
                        </div>

                        <div class="ledger-amount-pill ms-auto">
                            <span class="data-label">Total Due</span>
                            <span class="amount-value text-dark">Rs @item.TotalAmount.ToString("N2")</span>
                        </div>

                        <div class="ledger-row-actions">
                            <a href="@Url.Action("Details", "Billing", new { id = item.Id })" class="btn-ledger-circle shadow-sm" title="Detailed Audit">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-5 text-center bg-white rounded-5 shadow-sm border border-dashed border-2">
                    <i class="fas fa-shield-blank fs-1 mb-4 text-muted opacity-25"></i>
                    <h4 class="fw-900 text-dark">No Financial Records</h4>
                    <p class="text-muted mb-0">The system does not have any recorded transactions for the current period.</p>
                </div>
            }
        </div>
</div>

@section Scripts {
    <script>
        function filterInvoices() {
            let input = document.getElementById("invoiceSearch");
            let filter = input.value.toUpperCase();
            let cards = document.getElementsByClassName("ledger-row-card");

            for (let i = 0; i < cards.length; i++) {
                let name = cards[i].querySelector(".patient-name").innerText.toUpperCase();
                let ref = cards[i].querySelector(".invoice-ref").innerText.toUpperCase();
                
                if (name.indexOf(filter) > -1 || ref.indexOf(filter) > -1) {
                    cards[i].style.display = "flex";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }

        function applyStatusFilter(status, btn) {
            document.querySelectorAll('.btn-premium-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            let cards = document.getElementsByClassName("ledger-row-card");
            for (let i = 0; i < cards.length; i++) {
                if (status === 'all' || cards[i].getAttribute('data-status') === status) {
                    cards[i].style.display = "flex";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }
    </script>
}
