@model IEnumerable<CareFleet.Models.Prescription>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole") ?? "Patient";
    ViewData["Title"] = userRole == "Doctor" ? "Prescription History" : "My Prescriptions";
    Layout = userRole == "Doctor" ? "~/Views/Shared/_DoctorLayout.cshtml" : "~/Views/Shared/_PatientLayout.cshtml";
    ViewBag.ActivePage = "Prescriptions";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/prescription.css" asp-append-version="true" />
    <style>
        .stat-icon-wrapper {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        .stat-icon-wrapper.blue { background: #eff6ff; color: #3b82f6; }
        .stat-icon-wrapper.green { background: #f0fdf4; color: #22c55e; }
        .stat-icon-wrapper.dark { background: #f8fafc; color: #1e293b; }
        .avatar-sm-premium {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
        }
    </style>
}

<div class="container-fluid py-4 prescription-container">
    <!-- Premium Header -->
    <div class="premium-header-card mb-5">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-800 text-white mb-2">@(userRole == "Doctor" ? "Prescription History" : "My Prescriptions")</h1>
                <p class="text-white opacity-75 mb-0">
                    @(userRole == "Doctor" ? "Review and manage digital prescriptions issued to your patients." : "View and download prescriptions issued by your doctors.")
                </p>
            </div>
            <div class="header-actions">
                <div class="d-flex align-items-center gap-3">
                    <div class="search-box-modern">
                        <i class="fas fa-search"></i>
                        <input type="text" id="rxSearch" placeholder="Search..." onkeyup="filterHistory()">
                    </div>
                    @if (userRole == "Doctor")
                    {
                        <a href="@Url.Action("Create", "Prescription")" class="btn-premium-light">
                            <i class="fas fa-plus-circle me-2"></i>Create New
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Stats Row (Floating Style) -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="prescription-card p-4 text-center">
                <div class="stat-icon-wrapper blue mx-auto mb-3">
                    <i class="fas fa-file-medical"></i>
                </div>
                <h3 class="fw-800 mb-0">@Model.Count()</h3>
                <p class="text-muted small text-uppercase fw-bold mb-0">Total @(userRole == "Doctor" ? "Issued" : "Received")</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="prescription-card p-4 text-center">
                <div class="stat-icon-wrapper green mx-auto mb-3">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3 class="fw-800 mb-0">@Model.Count(p => p.DateCreated.Date == DateTime.Today)</h3>
                <p class="text-muted small text-uppercase fw-bold mb-0">Issued Today</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="prescription-card p-4 text-center">
                <div class="stat-icon-wrapper dark mx-auto mb-3">
                    <i class="fas @(userRole == "Doctor" ? "fa-user-check" : "fa-user-md")"></i>
                </div>
                <h3 class="fw-800 mb-0">
                    @(userRole == "Doctor" ? Model.Select(p => p.PatientId).Distinct().Count() : Model.Select(p => p.DoctorId).Distinct().Count())
                </h3>
                <p class="text-muted small text-uppercase fw-bold mb-0">Unique @(userRole == "Doctor" ? "Patients" : "Doctors")</p>
            </div>
        </div>
    </div>

    <!-- Tabs for Filtering -->
    <div class="d-flex align-items-center mb-4 gap-3 bg-white p-2 rounded-4 shadow-sm border" style="width: fit-content;">
        <button class="btn btn-premium-tab active" onclick="filterByStatus('all')">
            <i class="fas fa-list-ul me-2"></i>All Records
        </button>
        <button class="btn btn-premium-tab" onclick="filterByStatus('active')">
            <i class="fas fa-clock me-2"></i>Active Meds
        </button>
        <button class="btn btn-premium-tab" onclick="filterByStatus('expired')">
            <i class="fas fa-exclamation-circle me-2"></i>Expired
        </button>
    </div>

    <div class="prescription-card p-0 overflow-hidden shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="rxTable">
                <thead class="bg-light border-bottom">
                    <tr class="text-secondary small fw-bold text-uppercase ls-1">
                        <th class="ps-4 py-3">Date Issued</th>
                        <th class="py-3">@(userRole == "Doctor" ? "Patient Details" : "Doctor Details")</th>
                        <th class="py-3">Medications Tracking</th>
                        <th class="py-3">Status</th>
                        <th class="pe-4 py-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="medicine-row">
                                <td class="ps-4">
                                    <div class="fw-800 text-dark">@item.DateCreated.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@item.DateCreated.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (userRole == "Doctor")
                                        {
                                            <div class="avatar-sm-premium bg-primary-subtle text-primary fw-800 me-3">
                                                @(item.Patient != null ? (item.Patient.FirstName.Substring(0, 1) + item.Patient.LastName.Substring(0, 1)) : "??")
                                            </div>
                                            <div>
                                                <div class="fw-800 text-dark search-target">@item.Patient?.FirstName @item.Patient?.LastName</div>
                                                <small class="text-muted">ID: #P-@item.PatientId</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="avatar-sm-premium bg-info-subtle text-info fw-800 me-3">
                                                @(item.Doctor != null ? (item.Doctor.FirstName.Substring(0, 1) + item.Doctor.LastName.Substring(0, 1)) : "??")
                                            </div>
                                            <div>
                                                <div class="fw-800 text-dark search-target">Dr. @item.Doctor?.FirstName @item.Doctor?.LastName</div>
                                                <small class="text-muted">@item.Doctor?.Specialization</small>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var med in item.Items)
                                        {
                                            var isExpired = med.ExpiryDate.HasValue && med.ExpiryDate < DateTime.Now;
                                            <div class="d-flex align-items-center justify-content-between p-2 rounded-3 @(isExpired ? "bg-danger-subtle" : "bg-light") border border-opacity-10" style="min-width: 250px;">
                                                <div>
                                                    <div class="fw-bold small @(isExpired ? "text-danger" : "text-primary")">@med.MedicineName</div>
                                                    <div class="x-small text-muted">@med.Dosage | Refills: <span class="fw-bold text-dark">@med.Refills</span></div>
                                                </div>
                                                <div class="text-end">
                                                    <div class="x-small fw-bold @(isExpired ? "text-danger" : "text-secondary")">Exp: @(med.ExpiryDate?.ToString("MMM yyyy") ?? "N/A")</div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var anyExpired = item.Items.Any(i => i.ExpiryDate.HasValue && i.ExpiryDate < DateTime.Now);
                                        var allExpired = item.Items.All(i => i.ExpiryDate.HasValue && i.ExpiryDate < DateTime.Now);
                                    }
                                    @if (allExpired)
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2 status-target" data-status="expired">
                                            <i class="fas fa-times-circle me-1"></i>Expired
                                        </span>
                                    }
                                    else if (anyExpired)
                                    {
                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2 status-target" data-status="active">
                                            <i class="fas fa-exclamation-circle me-1"></i>Partial Exp
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2 status-target" data-status="active">
                                            <i class="fas fa-check-circle me-1"></i>Active
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="@Url.Action("Details", "Prescription", new { id = item.Id })" class="btn btn-action-light">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="opacity-25 mb-3">
                                    <i class="fas fa-file-prescription" style="font-size: 5rem;"></i>
                                </div>
                                <h5 class="fw-bold text-muted">No Prescriptions Found</h5>
                                <p class="text-muted small">Prescriptions will appear here once they are issued.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterByStatus(status) {
            // Update tab UI
            document.querySelectorAll('.btn-premium-tab').forEach(btn => btn.classList.remove('active'));
            event.currentTarget.classList.add('active');

            let tr = document.querySelectorAll('#rxTable tbody tr.medicine-row');
            tr.forEach(row => {
                let statusBadge = row.querySelector('.status-target');
                let rowStatus = statusBadge.getAttribute('data-status');
                
                if (status === 'all' || rowStatus === status) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function filterHistory() {
            let input = document.getElementById("rxSearch");
            let filter = input.value.toUpperCase();
            let tr = document.querySelectorAll('#rxTable tbody tr.medicine-row');

            tr.forEach(row => {
                let nameCell = row.querySelector('.search-target');
                if (nameCell) {
                    let txtValue = nameCell.textContent || nameCell.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                }
            });
        }
    </script>
}
