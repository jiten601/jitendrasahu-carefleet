@model CareFleet.Models.Patient
@{
    ViewData["Title"] = "Add New Patient";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Patients";
    ViewBag.HeaderTitle = "Add New Patient";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
}

<div class="fade-in">
    <!-- Premium Header Card -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-bold text-white mb-2">Add New Patient</h1>
                <p class="text-white-50 mb-0">Register a new patient to the CareFleet registry</p>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Patients", "Admin")" class="btn-premium-light text-decoration-none">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>


<div class="form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="FirstName">
                    <i class="fas fa-user-tag"></i> First Name <span class="required">*</span>
                </label>
                <input asp-for="FirstName" class="form-control" required />
                <span asp-validation-for="FirstName" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LastName">
                    <i class="fas fa-user-tag"></i> Last Name <span class="required">*</span>
                </label>
                <input asp-for="LastName" class="form-control" required />
                <span asp-validation-for="LastName" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="Email">
                    <i class="fas fa-envelope-open"></i> Email Address
                </label>
                <input asp-for="Email" type="email" class="form-control"/>
                <span asp-validation-for="Email" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="PhoneNumber">
                    <i class="fas fa-mobile-alt"></i> Phone Number
                </label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="DateOfBirth">
                    <i class="fas fa-calendar-day"></i> Date of Birth <span class="required">*</span>
                </label>
                <input asp-for="DateOfBirth" type="date" class="form-control" required />
                <span asp-validation-for="DateOfBirth" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Gender">
                    <i class="fas fa-venus-mars"></i> Gender
                </label>
                <select asp-for="Gender" class="form-control">
                    <option value="">Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="BloodGroup">
                    <i class="fas fa-tint"></i> Blood Group
                </label>
                <select asp-for="BloodGroup" class="form-control">
                    <option value="">Select Blood Group</option>
                    <option value="A+">A+</option>
                    <option value="A-">A-</option>
                    <option value="B+">B+</option>
                    <option value="B-">B-</option>
                    <option value="AB+">AB+</option>
                    <option value="AB-">AB-</option>
                    <option value="O+">O+</option>
                    <option value="O-">O-</option>
                </select>
                <span asp-validation-for="BloodGroup" class="text-danger" style="font-size: 12px;"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Address">
                <i class="fas fa-map-marker-alt"></i> Address
            </label>
            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Address" class="text-danger" style="font-size: 12px;"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="MedicalHistory">
                <i class="fas fa-history"></i> Medical History
            </label>
            <textarea asp-for="MedicalHistory" class="form-control" rows="3" placeholder="Any previous conditions, allergies, or chronic illnesses..."></textarea>
            <span asp-validation-for="MedicalHistory" class="text-danger" style="font-size: 12px;"></span>
        </div>

        <div style="margin-top: 40px; display: flex; gap: 20px;">
            <button type="submit" class="btn-primary-small fw-bold" style="padding: 14px 40px; font-size: 16px;">
                <i class="fas fa-save"></i> Create Patient
            </button>
            <a href="@Url.Action("Patients", "Admin")" class="btn-primary-small" style="background: #f1f5f9; color: #475569; padding: 14px 40px; font-size: 16px; text-decoration: none; border: 1px solid #e2e8f0; box-shadow: none;">
                Cancel
            </a>
        </div>
    </form>
</div>
</div>
