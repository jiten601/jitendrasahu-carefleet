@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
}


@section Styles {
    <link rel="stylesheet" href="~/css/messaging.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/video-call.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}

<div class="messages-page-wrapper patient-theme fade-in">
    <!-- Header Card -->
    <div class="premium-header-card mb-2">
        <div class="header-card-content">
            <div class="header-info">
                <h2 class="fw-800 text-white mb-2">My Messages</h2>
                <p class="text-white opacity-75 mb-0">Stay connected with your healthcare providers.</p>
            </div>
            <div class="header-actions">
                <button class="btn-premium-light" onclick="startNewConversation()">
                    <i class="fas fa-plus me-2"></i>Start Conversation
                </button>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="dashboard-card messages-main-card">
        <div class="messages-split-layout">
            <!-- Sidebar: Conversations List -->
            <aside class="conversations-sidebar">
                <div class="sidebar-header-internal">
                    <h5 class="sidebar-title fw-bold">Conversations</h5>
                    <div class="search-box-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" id="contactSearch" class="search-input" placeholder="Search providers...">
                    </div>
                </div>

                <div class="conversations-list custom-scrollbar" id="conversationsList">
                    @if (ViewBag.Contacts != null && ((IEnumerable<CareFleet.Models.Doctor>)ViewBag.Contacts).Any())
                    {
                        foreach (var contact in (IEnumerable<CareFleet.Models.Doctor>)ViewBag.Contacts)
                        {
                            bool isActive = ViewBag.SelectedContactEmail == contact.Email;
                            <div class="conversation-item @(isActive ? "active" : "")"
                                 onclick="location.href='@Url.Action("Messages", "Patient", new { receiverEmail = contact.Email })'"
                                 data-name="dr. @contact.FirstName.ToLower() @contact.LastName.ToLower()">
                                <div class="position-relative">
                                    <div class="user-avatar-medium bg-light text-primary">
                                        <span>@(contact.FirstName[0])@(contact.LastName[0])</span>
                                    </div>
                                    <span class="status-indicator online"></span>
                                </div>
                                <div class="conversation-details">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h6 class="contact-name mb-0">Dr. @contact.FirstName @contact.LastName</h6>
                                        <span class="time-stamp">@contact.Specialization</span>
                                    </div>
                                    <p class="last-message text-truncate mb-0">Tap to start chatting</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="fas fa-users-slash fa-2x mb-3 opacity-10"></i>
                            <p class="small mb-0">No conversations found.</p>
                        </div>
                    }
                </div>

                <!-- Active Indicator Bar at bottom (matching image) -->
                <div class="p-2 bg-light bg-opacity-50">
                    <div class="progress" style="height: 8px; border-radius: 4px; background: #cbd5e1;">
                        <div class="progress-bar" style="width: 45%; background: #94a3b8;"></div>
                    </div>
                </div>
            </aside>

            <!-- Main: Chat Window -->
            <section class="chat-window">
                <header class="chat-window-header">
                    @{
                        var patientName = (string)ViewBag.SelectedContactName;
                        var initials = !string.IsNullOrEmpty(patientName) ?
                        (patientName.Contains(" ") ? patientName.Split(' ').Last().Substring(0, 1) : patientName.Substring(0, 1)) : "D";

                        CareFleet.Models.Doctor activeDoc = null;
                        if (ViewBag.Contacts != null && ViewBag.SelectedContactEmail != null)
                        {
                            var currentEmail = (string)ViewBag.SelectedContactEmail;
                            activeDoc = ((IEnumerable<CareFleet.Models.Doctor>)ViewBag.Contacts).FirstOrDefault(d => d.Email == currentEmail);
                        }
                    }
                    <div class="d-flex align-items-center">
                        <div class="user-avatar-medium bg-light text-primary me-3">
                            @if (!string.IsNullOrEmpty(patientName))
                            {
                                <span>@initials</span>
                            }
                            else
                            {
                                <i class="fas fa-user-md"></i>
                            }
                        </div>
                        <div>
                            <h6 class="fw-800 mb-0">@patientName</h6>
                            <div class="status-label d-flex align-items-center">
                                <span class="status-dot-mini"></span>
                                <span>Healthcare Provider</span>
                            </div>
                        </div>
                    </div>
                    <div class="header-tools d-flex gap-2">

                        <button class="btn-tool" onclick="startVideoCall('@ViewBag.SelectedContactEmail', '@patientName', '@initials')" title="Video Call">
                            <i class="fas fa-video"></i>
                        </button>
                        @if (activeDoc != null)
                        {
                            <button class="btn-tool" onclick="viewProviderProfile('@activeDoc.FirstName', '@activeDoc.LastName', '@activeDoc.Email', '@activeDoc.PhoneNumber', '@activeDoc.Specialization', '@initials')" title="Info">
                                <i class="fas fa-info-circle"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn-tool" title="Info" disabled>
                                <i class="fas fa-info-circle"></i>
                            </button>
                        }
                    </div>
                </header>

                <div class="chat-history-container custom-scrollbar" id="chatHistory">
                    @if (ViewBag.ChatHistory != null && ((IEnumerable<CareFleet.Models.Message>)ViewBag.ChatHistory).Any())
                    {
                        foreach (var msg in (IEnumerable<CareFleet.Models.Message>)ViewBag.ChatHistory)
                        {
                            bool isOutgoing = msg.SenderEmail == Context.Session.GetString("UserEmail");
                            <div class="message-group">
                                <div class="message-item @(isOutgoing ? "outgoing" : "incoming")">
                                    <div class="message-bubble shadow-sm position-relative">
                                        <button class="btn-delete-msg" onclick="deleteMessage(@msg.Id, this)" title="Delete message">
                                            <i class="fas fa-times"></i>
                                        </button>
                                        @if (!string.IsNullOrEmpty(msg.Content))
                                        {
                                            <div class="message-text">@msg.Content</div>
                                        }
                                        @if (!string.IsNullOrEmpty(msg.AttachmentPath))
                                        {
                                            <div class="message-attachment mt-2">
                                                <a href="@msg.AttachmentPath" target="_blank" class="attachment-link">
                                                    <i class="fas fa-file-download me-2"></i>
                                                    @msg.AttachmentName
                                                </a>
                                            </div>
                                        }
                                    </div>
                                    <div class="message-time">
                                        @msg.Timestamp.ToString("hh:mm tt")
                                        @if (isOutgoing)
                                        {
                                            <i class="fas fa-check-double ms-1 @(msg.IsRead ? "text-primary" : "")"></i>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else if (string.IsNullOrEmpty(ViewBag.SelectedContactEmail))
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-25">
                            <i class="fas fa-comments fa-4x mb-3"></i>
                            <h5 class="fw-bold">Your Conversations</h5>
                            <p>Select a provider to view your message history.</p>
                        </div>
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-25">
                            <i class="fas fa-comment-medical fa-4x mb-3"></i>
                            <p>No messages yet. Send a message to start.</p>
                        </div>
                    }
                </div>

                <footer class="chat-input-area">
                    <form asp-action="SendMessage" asp-controller="Patient" method="post" enctype="multipart/form-data" class="chat-input-form d-flex align-items-center gap-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="receiverEmail" value="@ViewBag.SelectedContactEmail" />
                        <label for="messageAttachment" class="btn-attach" style="cursor: pointer;">
                            <i class="fas fa-paperclip"></i>
                        </label>
                        <input type="file" name="file" id="messageAttachment" style="display: none;" onchange="updateFileNameDisplay(this)" />
                        <input type="text" name="content" id="messageContent" class="form-control message-input flex-grow-1" placeholder="Type your message here..." autocomplete="off">
                        <button type="submit" class="btn-send" @(string.IsNullOrEmpty(ViewBag.SelectedContactEmail) ? "disabled" : "")>
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                    <div id="file-name-display" class="small text-muted ms-5 ps-3" style="display: none;">
                        <i class="fas fa-file me-1"></i> <span id="selected-file-name"></span>
                        <button type="button" class="btn btn-sm text-danger p-0 ms-2" onclick="clearSelectedFile()"><i class="fas fa-times"></i></button>
                    </div>
                </footer>
            </section>
        </div>
    </div>
</div>
<br>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatHistory = document.getElementById('chatHistory');
        if(chatHistory) chatHistory.scrollTop = chatHistory.scrollHeight;

        // Search Filter
        const searchInput = document.getElementById('contactSearch');
        const convItems = document.querySelectorAll('.conversation-item');

        if(searchInput) {
            searchInput.addEventListener('input', function() {
                const term = this.value.toLowerCase();
                convItems.forEach(item => {
                    const name = item.getAttribute('data-name');
                    if(name.includes(term)) {
                        item.style.display = 'flex';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        }
    });

    function updateFileNameDisplay(input) {
        const display = document.getElementById('file-name-display');
        const nameSpan = document.getElementById('selected-file-name');
        if (input.files && input.files[0]) {
            nameSpan.textContent = input.files[0].name;
            display.style.display = 'block';
            document.getElementById('messageContent').required = false;
        } else {
            display.style.display = 'none';
        }
    }

    function clearSelectedFile() {
        const input = document.getElementById('messageAttachment');
        const display = document.getElementById('file-name-display');
        input.value = '';
        display.style.display = 'none';
        document.getElementById('messageContent').required = true;
    }

    function startNewConversation() {
        const contacts = [];
        @if (ViewBag.Contacts != null)
        {
                foreach (var contact in (IEnumerable<CareFleet.Models.Doctor>)ViewBag.Contacts)
                {
                        <text>
                        contacts.push({ email: '@contact.Email', name: 'Dr. @contact.FirstName @contact.LastName', spec: '@contact.Specialization' });
                        </text>
                }
        }

        if (contacts.length === 0) {
            Swal.fire({
                icon: 'info',
                title: 'No Providers Available',
                text: 'You do not have any healthcare providers to message yet. Please book an appointment first.',
                confirmButtonColor: '#3b82f6',
                background: '#ffffff',
                borderRadius: '16px',
                customClass: {
                    popup: 'premium-swal-popup',
                    confirmButton: 'premium-swal-confirm'
                }
            });
            return;
        }

        let optionsHtml = '<option value="" disabled selected>Select a provider...</option>';
        contacts.forEach(c => {
            optionsHtml += `<option value="${c.email}">${c.name} - ${c.spec}</option>`;
        });

        Swal.fire({
            title: '<h4 class="fw-bold mb-0">New Conversation</h4>',
            html: `
                <div class="text-start mt-3">
                    <label class="form-label text-muted small mb-2 fw-medium">Select Healthcare Provider</label>
                    <select id="new-conv-provider" class="form-select border-0 shadow-sm" style="border-radius:12px; background-color:#f8fafc; padding:12px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02) !important;">
                        ${optionsHtml}
                    </select>
                </div>
            `,
            showCancelButton: true,
            confirmButtonText: 'Start Chat',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#3b82f6',
            cancelButtonColor: '#94a3b8',
            background: '#ffffff',
            borderRadius: '16px',
            customClass: {
                popup: 'premium-swal-popup',
                confirmButton: 'premium-swal-confirm',
                cancelButton: 'premium-swal-cancel'
            },
            preConfirm: () => {
                const selectedEmail = document.getElementById('new-conv-provider').value;
                if (!selectedEmail) {
                    Swal.showValidationMessage('<i class="fas fa-exclamation-circle me-1"></i> Please select a provider');
                }
                return selectedEmail;
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Messages", "Patient")?receiverEmail=' + encodeURIComponent(result.value);
            }
        });
    }

    function deleteMessage(messageId, btn) {
        Swal.fire({
            title: 'Delete Message?',
            text: "This action cannot be undone!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel',
            background: '#ffffff',
            borderRadius: '16px',
            customClass: {
                popup: 'premium-swal-popup',
                confirmButton: 'premium-swal-confirm',
                cancelButton: 'premium-swal-cancel'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                fetch('@Url.Action("DeleteMessage", "Patient")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `id=${messageId}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const messageGroup = btn.closest('.message-group');
                        messageGroup.classList.add('fade-out');
                        setTimeout(() => messageGroup.remove(), 300);

                        Swal.fire({
                            title: 'Deleted!',
                            text: 'Your message has been removed.',
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false,
                            borderRadius: '16px'
                        });
                    } else {
                        Swal.fire('Error!', 'Failed to delete message.', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    Swal.fire('Error!', 'An error occurred while deleting.', 'error');
                });
            }
        });
    }

    function viewProviderProfile(firstName, lastName, email, phone, spec, initials) {
        Swal.fire({
            html: `
                <div class="text-center p-3">
                    <div class="user-avatar-large mx-auto bg-light text-primary mb-3" style="width: 80px; height: 80px; font-size: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; background-color: #e0f2fe !important; color: #0284c7 !important;">
                        <span>${initials}</span>
                    </div>
                    <h4 class="fw-bold mb-1">Dr. ${firstName} ${lastName}</h4>
                    <p class="text-muted mb-3"><i class="fas fa-user-md me-1"></i> ${spec}</p>

                    <div class="text-start bg-light rounded-3 p-3">
                        <div class="mb-2">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.75rem;">Email Address</small>
                            <span class="fw-medium">${email}</span>
                        </div>
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.75rem;">Phone Number</small>
                            <span class="fw-medium">${phone || 'Not provided'}</span>
                        </div>
                    </div>
                </div>
            `,
            showConfirmButton: false,
            showCloseButton: true,
            background: '#ffffff',
            borderRadius: '16px',
            customClass: {
                popup: 'premium-swal-popup border-0 shadow-lg'
            }
        });
    }
</script>
