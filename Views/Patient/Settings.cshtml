@model CareFleet.Models.Patient
@{
    ViewData["Title"] = "Profile Settings";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    
    var patient = Model ?? new CareFleet.Models.Patient { 
        Id = 0,
        FirstName = ViewBag.FirstName?.ToString() ?? "Patient", 
        LastName = ViewBag.LastName?.ToString() ?? "User", 
        Email = ViewBag.UserEmail?.ToString() ?? "patient@carefleet.com",
        CreatedAt = DateTime.Now.AddYears(-1)
    };
    
    var initials = ((patient.FirstName?.Length > 0 ? patient.FirstName.Substring(0, 1) : "P") + 
                   (patient.LastName?.Length > 0 ? patient.LastName.Substring(0, 1) : "A")).ToUpper();
    
    // Calculate profile completion
    int completedFields = 0;
    int totalFields = 6;
    if (!string.IsNullOrEmpty(patient.FirstName)) { completedFields++; }
    if (!string.IsNullOrEmpty(patient.LastName)) { completedFields++; }
    if (!string.IsNullOrEmpty(patient.Email)) { completedFields++; }
    if (!string.IsNullOrEmpty(patient.PhoneNumber)) { completedFields++; }
    if (!string.IsNullOrEmpty(patient.Address)) { completedFields++; }
    if (!string.IsNullOrEmpty(patient.BloodGroup)) { completedFields++; }
    int profileCompletion = (int)((completedFields / (double)totalFields) * 100);
}


<div class="settings-page fade-in">
    <!-- Premium Header Card -->
    <div class="premium-header-card mb-4">
        <div class="header-card-content">
            <div class="header-info">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div style="width:44px;height:44px;background:rgba(255,255,255,0.15);
                                border-radius:12px;display:flex;align-items:center;
                                justify-content:center;border:1px solid rgba(255,255,255,0.25);">
                        <i class="fas fa-user-cog" style="color:#fff;font-size:1.1rem;"></i>
                    </div>
                    <h2 class="fw-800 text-white mb-0">Account Settings</h2>
                </div>
                <p class="text-white opacity-75 mb-0">Manage your profile information, health details, and security preferences.</p>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Profile", "Patient")" class="btn-premium-light">
                    <i class="fas fa-id-badge me-2"></i>View Profile
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Patient Intelligence Summary -->
        <div class="col-lg-4">
            <div class="profile-summary-card sticky-sidebar elevation-1">
                <!-- Avatar Intelligence -->
                <div class="avatar-section">
                    <div class="avatar-wrapper">
                        <div class="avatar-large-circle">@initials</div>
                        <div class="avatar-upload-overlay">
                            <label for="avatarUpload" class="upload-trigger" title="Change photo">
                                <i class="fas fa-camera"></i>
                            </label>
                            <input type="file" id="avatarUpload" accept="image/*" style="display: none;">
                        </div>
                    </div>
                    <h4 class="profile-name">@patient.FirstName @patient.LastName</h4>
                    <p class="profile-email">@patient.Email</p>
                    <span class="verified-badge-inline">
                        <i class="fas fa-check-circle me-1"></i>CareFleet Secure Profile
                    </span>
                </div>

                <!-- Data Integrity Check -->
                <div class="completion-section">
                    <div class="completion-header">
                        <span class="completion-label">Profile Completion</span>
                        <span class="completion-percentage">@profileCompletion%</span>
                    </div>
                    <div class="progress-bar-custom">
                        <div class="progress-fill" style="width: @(profileCompletion)%"></div>
                    </div>
                    <p class="completion-hint lh-base mt-2">
                        @if (profileCompletion < 100)
                        {
                            <text><i class="fas fa-info-circle text-warning me-1"></i> Fill in all fields to complete your profile.</text>
                        }
                        else
                        {
                            <text><i class="fas fa-check-double text-success me-1"></i> Profile details are complete.</text>
                        }
                    </p>
                </div>

                <!-- Navigation Hub -->
                <div class="quick-actions-section">
                    <a href="#" class="quick-action-link" onclick="document.getElementById('personalTab').click(); return false;">
                        <i class="fas fa-user" style="color: #547792;"></i>
                        <span>Personal Info</span>
                        <i class="fas fa-chevron-right ms-auto v-small opacity-50"></i>
                    </a>
                    <a href="#" class="quick-action-link" onclick="document.getElementById('medicalTab').click(); return false;">
                        <i class="fas fa-notes-medical" style="color: #547792;"></i>
                        <span>Medical Info</span>
                        <i class="fas fa-chevron-right ms-auto v-small opacity-50"></i>
                    </a>
                    <a href="#" class="quick-action-link" onclick="document.getElementById('securityTab').click(); return false;">
                        <i class="fas fa-shield-alt" style="color: #547792;"></i>
                        <span>Security & Privacy</span>
                        <i class="fas fa-chevron-right ms-auto v-small opacity-50"></i>
                    </a>
                </div>

                <!-- System Metadata -->
                <div class="account-info-section">
                    <div class="info-row">
                        <span class="info-label">Member Since</span>
                        <span class="info-value">@patient.CreatedAt.ToString("MMM yyyy")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status</span>
                        <span class="status-badge-active">Active</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Contextual Settings Form -->
        <div class="col-lg-8">
            <!-- Professional Navigation Tabs -->
            <div class="settings-tabs">
                <button class="tab-btn active" data-tab="personal" id="personalTab">
                    <i class="fas fa-user me-2"></i>Personal Info
                </button>
                <button class="tab-btn" data-tab="medical" id="medicalTab">
                    <i class="fas fa-notes-medical me-2"></i>Medical Info
                </button>
                <button class="tab-btn" data-tab="security" id="securityTab">
                    <i class="fas fa-shield-alt me-2"></i>Security
                </button>
            </div>

            <form method="post" action="@Url.Action("Edit", "Patient")" id="settingsForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@patient.Id" />
                <input type="hidden" name="CreatedAt" value="@patient.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ss")" />
                <input type="hidden" name="Email" value="@patient.Email" />

                <!-- Content Matrix -->
                <div class="tab-content-wrapper">
                    <!-- Personal Registry Tab -->
                    <div class="tab-content active" data-content="personal">
                        <div class="settings-card elevation-1">
                            <div class="card-header-settings">
                                <h4 class="card-title-settings">
                                    <i class="fas fa-id-card me-2" style="color: #547792;"></i>Personal Details
                                </h4>
                                <p class="card-subtitle">Update your basic contact and identity information.</p>
                            </div>
                            <div class="card-body-settings">
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">First Name</label>
                                            <input type="text" class="form-control-modern" name="FirstName" value="@patient.FirstName" placeholder="Enter first name" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Last Name</label>
                                            <input type="text" class="form-control-modern" name="LastName" value="@patient.LastName" placeholder="Enter last name" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Email Address</label>
                                            <div class="input-lock-wrapper d-flex align-items-center">
                                                <input type="email" class="form-control-modern flex-grow-1" value="@patient.Email" readonly disabled style="background: #f8fafc; cursor: not-allowed; padding-right: 35px;">
                                                <i class="fas fa-lock text-muted position-absolute" style="right: 15px;"></i>
                                            </div>
                                            <small class="form-hint">Email address cannot be changed.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Phone Number</label>
                                            <input type="tel" class="form-control-modern" name="PhoneNumber" value="@patient.PhoneNumber" placeholder="+977 98XXXXXXXX">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Date of Birth</label>
                                            <input type="date" class="form-control-modern" name="DateOfBirth" value="@(patient.DateOfBirth == default ? "" : patient.DateOfBirth.ToString("yyyy-MM-dd"))">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Gender</label>
                                            <select class="form-control-modern" name="Gender">
                                                <option value="Male" selected="@(patient.Gender == "Male")">Male</option>
                                                <option value="Female" selected="@(patient.Gender == "Female")">Female</option>
                                                <option value="Other" selected="@(patient.Gender == "Other")">Other</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Home Address</label>
                                            <textarea class="form-control-modern" name="Address" rows="2" placeholder="Enter your full address...">@patient.Address</textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Clinical Profile Tab -->
                    <div class="tab-content" data-content="medical">
                        <div class="settings-card elevation-1">
                            <div class="card-header-settings">
                                <h4 class="card-title-settings">
                                    <i class="fas fa-heartbeat me-2" style="color: #547792;"></i>Medical Details
                                </h4>
                                <p class="card-subtitle">Manage your health history and medical information.</p>
                            </div>
                            <div class="card-body-settings">
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Blood Group</label>
                                            <input type="text" class="form-control-modern" name="BloodGroup" value="@patient.BloodGroup" placeholder="e.g. O+">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-group-modern">
                                            <label class="form-label-modern">Medical History</label>
                                            <textarea class="form-control-modern" name="MedicalHistory" rows="6" placeholder="Document allergies, existing conditions, surgical history...">@patient.MedicalHistory</textarea>
                                            <small class="form-hint"><i class="fas fa-shield-alt me-1" style="color: #547792;"></i> Your data is encrypted and secure.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Access & Privacy Tab -->
                    <div class="tab-content" data-content="security">
                        <div class="settings-card elevation-1">
                            <div class="card-header-settings">
                                <h4 class="card-title-settings">
                                    <i class="fas fa-shield-alt me-2" style="color: #547792;"></i>Password & Security
                                </h4>
                                <p class="card-subtitle">Control your account access and security settings.</p>
                            </div>
                            <div class="card-body-settings">
                                <div class="security-notice">
                                    <i class="fas fa-info-circle" style="color: #547792;"></i>
                                    <div>
                                        <strong>Security Best Practices</strong>
                                        <p>Use a unique, strong password and rotate it regularly to protect your medical data.</p>
                                    </div>
                                </div>
                                <div class="row g-4 mt-1">
                                    <div class="col-12">
                                        <div class="security-item">
                                            <div class="security-item-icon">
                                                <i class="fas fa-key" style="color: #547792;"></i>
                                            </div>
                                            <div class="security-item-content">
                                                <h5 class="mb-1">Account Password</h5>
                                                <p class="small">Change your password regularly for better security.</p>
                                            </div>
                                            <button type="button" class="btn btn-outline-primary btn-sm px-4 rounded-pill ms-auto" style="height: fit-content;" disabled>
                                                Update
                                            </button>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="security-item">
                                            <div class="security-item-icon">
                                                <i class="fas fa-fingerprint" style="color: #547792;"></i>
                                            </div>
                                            <div class="security-item-content">
                                                <h5 class="mb-1">Two-Factor Authentication</h5>
                                                <p class="small">Add an extra layer of protection to your account.</p>
                                            </div>
                                            <button type="button" class="btn btn-primary btn-sm px-4 rounded-pill ms-auto" style="height: fit-content;" disabled>
                                                Enable
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Professional Action Matrix -->
                <div class="settings-actions">
                    <button type="button" class="btn-cancel" onclick="window.location.href='@Url.Action("Dashboard", "Patient")'">
                        Cancel
                    </button>
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/patient-settings.css" asp-append-version="true" />
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const tabs = document.querySelectorAll('.tab-btn');
        const contents = document.querySelectorAll('.tab-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.getAttribute('data-tab');

                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                contents.forEach(content => {
                    if (content.getAttribute('data-content') === target) {
                        content.classList.add('active');
                    } else {
                        content.classList.remove('active');
                    }
                });
            });
        });
    });
</script>
