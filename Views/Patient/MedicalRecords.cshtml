@model IEnumerable<CareFleet.Models.MedicalRecord>
@{
    ViewData["Title"] = "Medical Records";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewBag.ActivePage = "MedicalRecords";
    ViewBag.HeaderTitle = "Medical Records";
    ViewBag.HideHeader = true; // Utilizing premium header card
}

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient-medical-records.css" asp-append-version="true" />
}

<div class="premium-admin-container mt-2">
    <!-- Premium Header Card -->
    <div class="premium-header-card mb-4" style="background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-blue) 100%);">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="header-title-main">My Medical Records</h1>
                <p class="header-subtitle">
                    <i class="fas fa-file-medical-alt me-2"></i>
                    Securely manage your clinical reports and health history.
                </p>

                <div class="d-flex gap-3 mt-4">
                    <div class="premium-stat-card">
                        <div class="stat-icon-wrapper docs">
                            <i class="fas fa-file-medical-alt"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">Total Documents</span>
                            <span class="stat-value">@(Model?.Count() ?? 0)</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <button onclick="exportAllRecords()" class="btn-premium-light border-0" style="background: white; color: var(--primary-dark); padding: 12px 24px; border-radius: 12px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-file-csv"></i> Export Data
                </button>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Search & Filter Bar -->
    <div class="search-filter-section mb-4">
        <div class="search-input-wrapper flex-grow-1">
            <i class="fas fa-search"></i>
            <input type="text" id="recordSearch" placeholder="Search document name..." class="premium-search-input">
        </div>
        <div class="filter-actions d-flex gap-2">
            <select class="btn-filter" id="categoryFilter" style="appearance: none; cursor: pointer;">
                <option value="All Categories">All Categories</option>
                <option value="Laboratory">Laboratory</option>
                <option value="Radiology">Radiology</option>
                <option value="General Health">General</option>
            </select>
            <button class="btn-filter" onclick="window.location.reload()">
                <i class="fas fa-sync-alt fw-bold"></i>
            </button>
        </div>
    </div>

    <!-- Table Section -->
    <div class="table-glass-wrapper shadow-lg overflow-visible mb-5">
        <table class="table premium-table mb-0" id="recordsTable">
            <thead>
                <tr>
                    <th class="ps-4">Document Name</th>
                    <th>Medical Category</th>
                    <th>Date Published</th>
                    <th>Clinical Provider</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="recordsTableBody">
                @if (Model != null && Model.Any())
                {
                    foreach (var record in Model)
                    {
                        var iconClass = record.Category switch
                        {
                            "Laboratory" => "fa-vials",
                            "Radiology" => "fa-x-ray",
                            _ => "fa-file-medical"
                        };
                        var themeColor = record.Category switch
                        {
                            "Laboratory" => "rgba(59, 130, 246, 0.1)",
                            "Radiology" => "rgba(245, 158, 11, 0.1)",
                            _ => "rgba(84, 119, 146, 0.1)"
                        };
                        var iconTextColor = record.Category switch
                        {
                            "Laboratory" => "#3b82f6",
                            "Radiology" => "#d97706",
                            _ => "var(--primary-blue)"
                        };

                        <tr class="record-row" data-category="@record.Category" data-name="@record.DocumentName.ToLower()">
                            <td class="ps-4">
                                <div class="patient-identity">
                                    <div class="patient-avatar" style="background: @themeColor; color: @iconTextColor; border-radius: 12px;">
                                        <i class="fas @iconClass"></i>
                                    </div>
                                    <div class="patient-info">
                                        <span class="patient-name fw-bold doc-name" style="color: var(--primary-dark);">@record.DocumentName</span>
                                        <span class="patient-id" style="color: var(--text-secondary);">@record.FileType Document • @(string.IsNullOrEmpty(record.FilePath) ? "N/A" : "Ready")</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span class="spec-pill fw-bold doc-cat" style="background: rgba(84, 119, 146, 0.05); color: var(--primary-blue); border: 1px solid rgba(84, 119, 146, 0.1);">
                                        @record.Category
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span class="data-label fw-bold doc-date" style="color: var(--primary-dark);">@record.DateIssued.ToString("MMM dd, yyyy")</span>
                                </div>
                            </td>
                            <td>
                                <div>
                                    <span class="data-label fw-bold doc-provider" style="color: var(--primary-dark);">@record.Provider</span>
                                    <span class="data-sublabel" style="color: var(--text-secondary);">Healthcare Team</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("ViewRecord", "Patient", new { id = record.Id })" class="btn-action-premium view" title="View Report">
                                        <i class="fas fa-eye text-primary"></i>
                                    </a>
                                    <a href="@Url.Action("DownloadRecord", "Patient", new { id = record.Id })" class="btn-action-premium edit" title="Download Document">
                                        <i class="fas fa-download text-success"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <div class="empty-state">
                                <i class="fas fa-folder-open mb-4" style="font-size: 4.5rem; color: #cbd5e1; opacity: 0.4;"></i>
                                <h3 style="color: var(--primary-dark); font-family: 'Outfit', sans-serif; font-weight: 700;">No Medical Records</h3>
                                <p style="color: var(--text-secondary); font-weight: 500;">Your clinical file archive is currently empty.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('recordSearch');
        const filterSelect = document.getElementById('categoryFilter');
        const rows = document.querySelectorAll('.record-row');

        function filterRecords() {
            const searchTerm = searchInput.value.toLowerCase();
            const selectedCategory = filterSelect.value;
            let visibleCount = 0;

            rows.forEach(row => {
                const name = row.dataset.name;
                const category = row.dataset.category;

                const matchesSearch = name.includes(searchTerm);
                const matchesCategory = selectedCategory === 'All Categories' || category === selectedCategory;

                if (matchesSearch && matchesCategory) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
        }

        if (searchInput) searchInput.addEventListener('input', filterRecords);
        if (filterSelect) filterSelect.addEventListener('change', filterRecords);

        // Export functionality (CSV)
        window.exportAllRecords = function() {
            const csvData = [];
            const headers = ['Document Name', 'Category', 'Date Issued', 'Provider'];
            csvData.push(headers.join(','));

            rows.forEach(row => {
                if (row.style.display !== 'none') {
                    const documentName = row.querySelector('.doc-name').innerText;
                    const category = row.querySelector('.doc-cat').innerText;
                    const dateIssued = row.querySelector('.doc-date').innerText;
                    const provider = row.querySelector('.doc-provider').innerText;

                    csvData.push(`"${documentName}","${category}","${dateIssued}","${provider}"`);
                }
            });

            if (csvData.length <= 1) {
                alert('No records available to export.');
                return;
            }

            const blob = new Blob([csvData.join('\n')], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('hidden', '');
            a.setAttribute('href', url);
            a.setAttribute('download', 'MedicalRecords_Export.csv');
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        };
    });
</script>