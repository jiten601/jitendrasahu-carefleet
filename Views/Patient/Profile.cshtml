@model CareFleet.Models.Patient
@{
    ViewData["Title"] = "Patient Profile";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    
    var patient = Model ?? new CareFleet.Models.Patient { 
        Id = 0,
        FirstName = ViewBag.FirstName?.ToString() ?? "Patient", 
        LastName = ViewBag.LastName?.ToString() ?? "User", 
        Email = ViewBag.UserEmail?.ToString() ?? "patient@carefleet.com",
        CreatedAt = DateTime.Now.AddYears(-1)
    };
    
    var initials = ((patient.FirstName?.Length > 0 ? patient.FirstName.Substring(0, 1) : "P") + 
                   (patient.LastName?.Length > 0 ? patient.LastName.Substring(0, 1) : "A")).ToUpper();
    
    var memberSince = patient.CreatedAt.ToString("MMMM yyyy");
}

<div class="profile-page fade-in">
    <!-- Premium Header Card -->
    <div class="premium-header-card mb-4">
        <div class="header-card-content">
            <div class="header-info">
                <div class="header-breadcrumb mb-2">
                    <a href="@Url.Action("Dashboard", "Patient")" class="text-white text-decoration-none opacity-75 hvr-opacity">Dashboard</a>
                    <i class="fas fa-chevron-right mx-2 small opacity-50 text-white"></i>
                    <span class="text-white fw-bold">My Profile</span>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div class="header-avatar-circle">@initials</div>
                    <div>
                        <h2 class="fw-800 text-white mb-2">@patient.FirstName @patient.LastName</h2>
                        <div class="d-flex gap-3 flex-wrap">
                            <span class="info-badge-light">
                                <i class="fas fa-id-card me-2"></i>ID: PAT-@(patient.Id.ToString("D4"))
                            </span>
                            <span class="info-badge-light">
                                <i class="fas fa-check-circle me-2"></i>Verified Profile
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Settings", "Patient")" class="btn-premium-light">
                    <i class="fas fa-user-cog me-2"></i>Edit Settings
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Main Content Area -->
    <div class="row g-4 mt-1">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Medical Overview Card -->
            <div class="premium-card mb-4 elevation-1">
                <div class="card-header-premium d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-notes-medical text-primary me-2"></i>Health Overview
                    </h5>
                    <span class="badge bg-light text-primary border px-3 py-2 rounded-pill">Active Patient</span>
                </div>
                <div class="card-body-premium">
                    <div class="bio-section mb-4">
                        <h6 class="text-uppercase x-small fw-800 text-secondary ls-1 mb-3">Medical History</h6>
                        <p class="text-secondary lh-lg mb-0 text-justify">
                            @(string.IsNullOrEmpty(patient.MedicalHistory) ? "No medical history recorded yet. Please update your profile in settings to provide your health narrative." : patient.MedicalHistory)
                        </p>
                    </div>
                </div>
            </div>

            <!-- Health Vital Stats Section -->
            <div class="row g-4 mb-4">
                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-danger text-danger">
                            <i class="fas fa-dna"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Blood Group</span>
                            <span class="vital-value">@(string.IsNullOrEmpty(patient.BloodGroup) ? "N/A" : patient.BloodGroup)</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-primary text-primary">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Gender</span>
                            <span class="vital-value">@patient.Gender</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-info text-info">
                            <i class="fas fa-birthday-cake"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Date of Birth</span>
                            <span class="vital-value text-nowrap">@patient.DateOfBirth.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="vital-card">
                        <div class="vital-icon bg-soft-success text-success">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="vital-info">
                            <span class="vital-label">Status</span>
                            <span class="vital-value">Active</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Enhanced Timeline Card -->
            <div class="premium-card elevation-1">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-history text-primary me-2"></i>My Timeline
                    </h5>
                </div>
                <div class="card-body-premium p-0">
                    <div class="journey-timeline p-4">
                        <div class="journey-item">
                            <div class="journey-marker current"></div>
                            <div class="journey-content">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0">Profile Created</h6>
                                    <span class="journey-time">@patient.CreatedAt.AddMinutes(5).ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-secondary small mb-0">Your account was successfully set up and active.</p>
                            </div>
                        </div>
                        <div class="journey-item">
                            <div class="journey-marker"></div>
                            <div class="journey-content">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0">Joined CareFleet</h6>
                                    <span class="journey-time">@patient.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="text-secondary small mb-0">Welcome to the CareFleet healthcare community.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Professional Contact Card -->
            <div class="premium-card mb-4 elevation-1 sticky-card">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0"><i class="fas fa-address-book text-primary me-2"></i>Contact Details</h5>
                </div>
                <div class="card-body-premium">
                    <div class="registry-item mb-4">
                        <div class="registry-icon"><i class="fas fa-envelope"></i></div>
                        <div class="registry-detail">
                            <label>Email</label>
                            <p>@patient.Email</p>
                        </div>
                    </div>
                    <div class="registry-item mb-4">
                        <div class="registry-icon"><i class="fas fa-phone"></i></div>
                        <div class="registry-detail">
                            <label>Phone</label>
                            <p>@(string.IsNullOrEmpty(patient.PhoneNumber) ? "Not Provided" : patient.PhoneNumber)</p>
                        </div>
                    </div>
                    <div class="registry-item">
                        <div class="registry-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="registry-detail">
                            <label>Address</label>
                            <p>@(string.IsNullOrEmpty(patient.Address) ? "Update required" : patient.Address)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Care & Quick Planning Card -->
            <div class="premium-card mb-4 elevation-1">
                <div class="card-header-premium">
                    <h5 class="fw-bold mb-0"><i class="fas fa-calendar-alt text-primary me-2"></i>Appointments</h5>
                </div>
                <div class="card-body-premium">
                    <div class="planning-row mb-3">
                        <span class="text-secondary fw-600">Last Consultation</span>
                        <span class="fw-bold">No records</span>
                    </div>
                    <div class="planning-row mb-4">
                        <span class="text-secondary fw-600">Upcoming Visit</span>
                        <span class="badge bg-soft-primary text-primary px-3">Syncing...</span>
                    </div>
                    <div class="d-grid">
                        <a href="@Url.Action("Book", "Appointment")" class="btn btn-primary btn-premium-action py-3">
                            <i class="fas fa-calendar-plus me-2"></i>Book Appointment
                        </a>
                    </div>
                </div>
            </div>

            <!-- Enhanced Activity Board -->
            <div class="premium-card elevation-1">
                <div class="card-header-premium bg-light-soft">
                    <h5 class="fw-bold mb-0"><i class="fas fa-chart-line text-primary me-2"></i>Activity Board</h5>
                </div>
                <div class="card-body-premium p-0">
                    <div class="activity-grid">
                        <a href="@Url.Action("Appointments", "Patient")" class="activity-box">
                            <span class="activity-val">@ViewBag.AppointmentCount</span>
                            <span class="activity-lab">Visits</span>
                        </a>
                        <a href="@Url.Action("MedicalRecords", "Patient")" class="activity-box border-start">
                            <span class="activity-val">@ViewBag.RecordCount</span>
                            <span class="activity-lab">Files</span>
                        </a>
                    </div>
                    <div class="activity-footer py-3 text-center border-top bg-light-v-soft">
                        <span class="text-secondary v-small fw-bold text-uppercase">Member since @memberSince</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/patient-profile.css" asp-append-version="true" />
}
