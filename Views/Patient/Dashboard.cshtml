@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
}

<div class="dashboard-wrapper">
    <!-- Welcome Section (Premium Style) -->
    <div class="premium-header-card mb-4">
        <div class="header-card-content">
            <div class="header-info">
                <h1 class="fw-800 text-white mb-2"><i class="fas fa-home me-2"></i>Welcome Back, @ViewBag.FirstName!</h1>
                @if (ViewBag.UpcomingAppointment != null)
                {
                    <p class="text-white opacity-75 mb-0">Your recovery progress is looking great. You have an appointment with Dr. @ViewBag.UpcomingAppointment.DoctorName on @ViewBag.UpcomingAppointment.AppointmentDate.ToString("MMM dd") at @ViewBag.UpcomingAppointment.AppointmentDate.ToString("hh:mm tt").</p>
                }
                else
                {
                    <p class="text-white opacity-75 mb-0">Your recovery progress is looking great. Keep up the healthy habits!</p>
                }
            </div>
            <div class="header-actions">
                <a href="@Url.Action("Appointments", "Patient")" class="btn-premium-light">
                    <i class="fas fa-calendar-check me-2"></i>View Schedule
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="dashboard-card p-4 shadow-sm h-100 clickable-card" onclick="location.href='@Url.Action("Appointments", "Patient")'">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-secondary small fw-bold text-uppercase mb-1">Upcoming Appointment</p>
                        @if (ViewBag.UpcomingAppointment != null)
                        {
                            <h5 class="fw-bold mb-0"> @ViewBag.UpcomingAppointment.DoctorName</h5>
                            <small class="text-primary fw-bold">@ViewBag.UpcomingAppointment.AppointmentDate.ToString("MMM dd, yyyy")</small>
                        }
                        else
                        {
                            <h5 class="fw-bold mb-0 text-muted">No Appointments</h5>
                            <small class="text-secondary">Schedule one today</small>
                        }
                    </div>
                    <div class="stat-icon bg-primary-soft text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-card p-4 shadow-sm h-100 clickable-card" onclick="location.href='@Url.Action("Messages", "Patient")'">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-secondary small fw-bold text-uppercase mb-1">Communications</p>
                        <h5 class="fw-bold mb-0">Messages</h5>
                        <small class="text-success fw-bold">Check inbox</small>
                    </div>
                    <div class="stat-icon bg-info-soft text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-comment-dots"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-card p-4 shadow-sm h-100 clickable-card" onclick="location.href='@Url.Action("MedicalRecords", "Patient")'">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-secondary small fw-bold text-uppercase mb-1">Medical Records</p>
                        <h5 class="fw-bold mb-0">Health Docs</h5>
                        <small class="text-secondary fw-bold">View history</small>
                    </div>
                    <div class="stat-icon bg-success-soft text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-file-medical"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="dashboard-card p-4 shadow-sm h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Recent Activity</h5>
                    <a href="@Url.Action("ActivityHistory", "Patient")" class="text-primary small fw-bold">View All</a>
                </div>
                <div class="activity-timeline">
                    @if (ViewBag.RecentActivities != null && ((IEnumerable<CareFleet.Models.PatientActivity>)ViewBag.RecentActivities).Any())
                    {
                        foreach (var activity in (IEnumerable<CareFleet.Models.PatientActivity>)ViewBag.RecentActivities)
                        {
                            <div class="activity-item d-flex gap-3 mb-4">
                                <div class="activity-icon bg-light rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="min-width: 40px; height: 40px;">
                                    <i class="@activity.Icon text-primary small"></i>
                                </div>
                                <div>
                                    <p class="mb-1 fw-bold small">@activity.Title</p>
                                    <p class="text-secondary x-small mb-0">@activity.Date.ToString("MMM dd, yyyy") • @activity.Subtitle</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p class="text-muted small mb-0">No recent activities found.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="dashboard-card p-4 shadow-sm h-100">
                <h5 class="fw-bold mb-4">Health Tips</h5>
                @if (ViewBag.HealthTips != null)
                {
                    foreach (var tip in (IEnumerable<CareFleet.Models.HealthTip>)ViewBag.HealthTips)
                    {
                        <div class="tip-card p-3 rounded-3 mb-3" style="background: #f8fafc; border: 1px dashed #cbd5e1;">
                            <i class="@tip.Icon @tip.ColorClass mb-2"></i>
                            <p class="small fw-medium mb-1">@tip.Title</p>
                            <p class="x-small text-secondary mb-0">@tip.Content</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/patient-dashboard.css" asp-append-version="true" />
}
