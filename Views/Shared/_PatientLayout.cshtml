@{
    var firstName = ViewBag.FirstName?.ToString() ?? "Patient";
    var lastName = ViewBag.LastName?.ToString() ?? "";
    var initials = firstName.Length > 0 ? firstName.Substring(0, 1) : "";
    initials += lastName.Length > 0 ? lastName.Substring(0, 1) : "";
    var activePage = ViewBag.ActivePage?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CareFleet</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h3 class="logo fw-bold">CareFleet</h3>
            </div>
            <nav class="sidebar-nav">
                <a href="@Url.Action("Dashboard", "Patient")" class="nav-item @(activePage == "Dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Profile", "Patient")" class="nav-item @(activePage == "Profile" ? "active" : "")">
                    <i class="fas fa-user-circle"></i>
                    <span>My Profile</span>
                </a>
                <a href="@Url.Action("Appointments", "Patient")" class="nav-item @(activePage == "Appointments" ? "active" : "")">
                    <i class="fas fa-calendar-alt"></i>
                    <span>My Appointments</span>
                </a>
                <a href="@Url.Action("MedicalRecords", "Patient")" class="nav-item @(activePage == "MedicalRecords" ? "active" : "")">
                    <i class="fas fa-file-medical"></i>
                    <span>Medical Records</span>
                </a>
                <a href="@Url.Action("MyPrescriptions", "Prescription")" class="nav-item @(activePage == "Prescriptions" ? "active" : "")">
                    <i class="fas fa-file-prescription"></i>
                    <span>My Prescriptions</span>
                </a>
                <a href="@Url.Action("Messages", "Patient")" class="nav-item @(activePage == "Messages" ? "active" : "")">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
                <a href="@Url.Action("MyInvoices", "Billing")" class="nav-item @(activePage == "Payments" ? "active" : "")">
                    <i class="fas fa-credit-card"></i>
                    <span>Payments</span>
                </a>
                <a href="@Url.Action("Settings", "Patient")" class="nav-item @(activePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Top Header -->
            <header class="content-header px-4">
                <h2 class="welcome-text fw-bold">@ViewBag.HeaderTitle</h2>
                <div class="header-actions">
                    <div class="notification-container">
                        <button class="notification-btn notiBtn">
                            <i class="fas fa-bell"></i>
                            @if (ViewBag.UnreadNotifications > 0)
                            {
                                <span class="notification-badge notiBadge">@ViewBag.UnreadNotifications</span>
                            }
                        </button>
                        <div class="notification-dropdown notiDropdown">
                            <div class="notification-header">
                                <h5 class="text-dark">Notifications</h5>
                                <button class="mark-all-btn" onclick="markAllAsRead(event)">Mark all as read</button>
                            </div>
                            <div class="notification-list notiList">
                                <div class="notification-empty">Loading notifications...</div>
                            </div>
                        </div>
                    </div>
                    <div class="user-profile dropdown" id="dropdownTrigger">
                        <div class="avatar">@initials.ToUpper()</div>
                        <i class="fas fa-chevron-down ms-2"></i>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3" id="userMenu">
                            @* <li><h6 class="dropdown-header">@firstName @lastName</h6></li> *@
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Patient")"><i class="fas fa-user-circle me-2"></i>My Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="dashboard-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show alert-premium alert-premium-success mb-4" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div class="text-dark fw-medium">@TempData["Success"]</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#dropdownTrigger').on('click', function(e) {
                $('#userMenu').toggleClass('show');
                e.stopPropagation();
            });
            $(document).on('click', function() {
                $('#userMenu').removeClass('show');
            });
        });

        // Notification Logic
        function fetchNotifications() {
            fetch('/Notification/GetNotifications')
                .then(response => response.json())
                .then(data => {
                    const lists = document.querySelectorAll('.notiList');
                    lists.forEach(list => {
                        if (data.length === 0) {
                            list.innerHTML = '<div class="notification-empty">No notifications yet</div>';
                            return;
                        }

                        list.innerHTML = data.map(item => `
                            <div class="notification-item ${item.isRead ? '' : 'unread'}"
                                 style="cursor:pointer;"
                                 onclick="handleNotificationClick(${item.id}, '${item.targetUrl}', event)">
                                <div class="notification-content text-dark">${item.message}</div>
                                <div class="notification-time">${item.createdAt}</div>
                            </div>
                        `).join('');
                    });

                    // Update badge count
                    const unreadCount = data.filter(n => !n.isRead).length;
                    document.querySelectorAll('.notiBadge').forEach(b => {
                        if (unreadCount > 0) {
                            b.textContent = unreadCount;
                            b.style.display = '';
                        } else {
                            b.style.display = 'none';
                        }
                    });
                });
        }

        function handleNotificationClick(id, targetUrl, e) {
            e.stopPropagation();
            // Mark as read then navigate
            fetch('/Notification/MarkAsRead/' + id, { method: 'POST' })
                .then(response => {
                    if (targetUrl && targetUrl !== '') {
                        window.location.href = targetUrl;
                    } else {
                        fetchNotifications();
                    }
                });
        }

        function markAsRead(id, e) {
            e.stopPropagation();
            fetch('/Notification/MarkAsRead/' + id, { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        fetchNotifications();
                    }
                });
        }

        function markAllAsRead(e) {
            e.stopPropagation();
            fetch('/Notification/MarkAllAsRead', { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        fetchNotifications();
                        document.querySelectorAll('.notiBadge').forEach(b => b.style.display = 'none');
                    }
                });
        }

        document.querySelectorAll('.notiBtn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const dropdown = this.parentElement.querySelector('.notiDropdown');
                const isShowing = dropdown.classList.contains('show');
                
                document.querySelectorAll('.notiDropdown.show').forEach(d => d.classList.remove('show'));
                
                if (!isShowing) {
                    dropdown.classList.add('show');
                    fetchNotifications();
                }
            });
        });

        $(document).on('click', function(event) {
            if (!$(event.target).closest('.notification-container').length) {
                $('.notiDropdown.show').removeClass('show');
            }
        });

        // Track last visited page
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            if (currentPath && !currentPath.includes('/Account/')) {
                const expires = new Date();
                expires.setTime(expires.getTime() + (30 * 24 * 60 * 60 * 1000));
                document.cookie = "LastVisitedPath=" + currentPath + ";expires=" + expires.toUTCString() + ";path=/";
            }
        });
    </script>
    <partial name="_VideoCallModal" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
