@{
    var firstName = ViewBag.FirstName?.ToString() ?? "Doctor";
    var lastName = ViewBag.LastName?.ToString() ?? "";
    var initials = firstName.Length > 0 ? firstName.Substring(0, 1) : "";
    initials += lastName.Length > 0 ? lastName.Substring(0, 1) : "";
    var activePage = ViewBag.ActivePage?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CareFleet</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/doctor-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="dashboard-container">
        <!-- Mobile Sidebar Toggle -->
        <button class="sidebar-toggle-mobile" id="sidebarToggleMobile">
            <i class="fas fa-bars"></i>
        </button>

        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h3 class="logo">CareFleet</h3>
            </div>
            <nav class="sidebar-nav">
                <a href="@Url.Action("Dashboard", "Doctor")" class="nav-item @(activePage == "Dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Appointments", "Doctor")" class="nav-item @(activePage == "Appointments" ? "active" : "")">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Appointments</span>
                </a>
                <a href="@Url.Action("Patients", "Doctor")" class="nav-item @(activePage == "Patients" ? "active" : "")">
                    <i class="fas fa-user-friends"></i>
                    <span>Patients</span>
                </a>
                <a href="@Url.Action("Messages", "Doctor")" class="nav-item @(activePage == "Messages" ? "active" : "")">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
                <a href="@Url.Action("MedicalRecords", "Doctor")" class="nav-item @(activePage == "MedicalRecords" ? "active" : "")">
                    <i class="fas fa-file-medical"></i>
                    <span>Medical Records</span>
                </a>
                <a href="@Url.Action("MyPrescriptions", "Prescription")" class="nav-item @(activePage == "Prescriptions" ? "active" : "")">
                    <i class="fas fa-prescription"></i>
                    <span>Prescriptions</span>
                </a>
                <a href="@Url.Action("AllInvoices", "Billing")" class="nav-item @(activePage == "Billing" ? "active" : "")">
                    <i class="fas fa-file-invoice-dollar"></i>
                    <span>Billing</span>
                </a>
                <a href="@Url.Action("Settings", "Doctor")" class="nav-item @(activePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            @if (ViewBag.HideHeader != true)
            {
                <!-- Top Header -->
                <header class="content-header px-4">
                    @if (activePage == "Dashboard")
                    {
                        <h2 class="welcome-text fw-bold">Welcome, Dr. @firstName @lastName!</h2>
                    }
                    else
                    {
                        <h2 class="welcome-text fw-bold">@ViewBag.HeaderTitle</h2>
                    }
                    <div class="header-actions">
                        <div class="notification-container">
                            <button class="notification-btn notiBtn">
                                <i class="fas fa-bell"></i>
                                @if (ViewBag.UnreadNotifications > 0)
                                {
                                    <span class="notification-badge notiBadge">@ViewBag.UnreadNotifications</span>
                                }
                            </button>
                            <div class="notification-dropdown notiDropdown">
                                <div class="notification-header">
                                    <h5 class="text-dark">Notifications</h5>
                                    <button class="mark-all-btn" onclick="markAllAsRead(event)">Mark all as read</button>
                                </div>
                                <div class="notification-list notiList">
                                    <div class="notification-empty">Loading notifications...</div>
                                </div>
                            </div>
                        </div>
                        <div class="user-profile dropdown" id="dropdownTrigger">
                            <div class="avatar">@initials.ToUpper()</div>
                            <i class="fas fa-chevron-down ms-2"></i>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3" id="userMenu">
                                <li><h6 class="dropdown-header">Dr. @firstName @lastName</h6></li>
                                <li><a class="dropdown-item" href="@Url.Action("Settings", "Doctor")"><i class="fas fa-user-md me-2"></i>My Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </header>
            }
            else
            {
                <!-- Minimal Header when using Premium Card -->
                <header class="content-header px-4 mb-0">
                    @if (activePage == "Dashboard")
                    {
                        <h2 class="welcome-text fw-bold">Welcome, Dr. @firstName @lastName!</h2>
                    }
                    else
                    {
                        <h2 class="welcome-text fw-bold">@ViewBag.HeaderTitle</h2>
                    }
                    <div class="header-actions">
                        <div class="notification-container">
                            <button class="notification-btn notiBtn">
                                <i class="fas fa-bell"></i>
                                @if (ViewBag.UnreadNotifications > 0)
                                {
                                    <span class="notification-badge notiBadge">@ViewBag.UnreadNotifications</span>
                                }
                            </button>
                            <div class="notification-dropdown notiDropdown">
                                <div class="notification-header">
                                    <h5 class="text-dark">Notifications</h5>
                                    <button class="mark-all-btn" onclick="markAllAsRead(event)">Mark all as read</button>
                                </div>
                                <div class="notification-list notiList">
                                    <div class="notification-empty">Loading notifications...</div>
                                </div>
                            </div>
                        </div>
                        <div class="user-profile dropdown" id="dropdownTrigger">
                            <div class="avatar">@initials.ToUpper()</div>
                            <i class="fas fa-chevron-down ms-2"></i>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3" id="userMenu">
                                @* <li><h6 class="dropdown-header">Dr. @firstName @lastName</h6></li> *@
                                <li><a class="dropdown-item" href="@Url.Action("Settings", "Doctor")"><i class="fas fa-user-md me-2"></i>My Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </header>
            }


            <!-- Page Content -->
            <div class="dashboard-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show alert-premium alert-premium-success mb-4" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3 fs-5"></i>
                            <div class="text-dark fw-medium">@TempData["Success"]</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Simple dropdown toggle logic for the header (custom)
        $(document).ready(function() {
            $('#dropdownTrigger').on('click', function(e) {
                $('#userMenu').toggleClass('show');
                e.stopPropagation();
            });
            $(document).on('click', function() {
                $('#userMenu').removeClass('show');
            });
        });

        // Notification Logic
        function fetchNotifications() {
            fetch('/Notification/GetNotifications')
                .then(response => response.json())
                .then(data => {
                    const lists = document.querySelectorAll('.notiList');
                    lists.forEach(list => {
                        if (data.length === 0) {
                            list.innerHTML = '<div class="notification-empty">No notifications yet</div>';
                            return;
                        }
                        
                    list.innerHTML = data.map(item => {
                        let icon = 'fa-bell';
                        let iconClass = 'bg-primary-subtle text-primary';
                        const msg = item.message.toLowerCase();
                        
                        if (msg.includes('message')) { icon = 'fa-envelope'; iconClass = 'bg-info-subtle text-info'; }
                        else if (msg.includes('appointment')) { icon = 'fa-calendar-check'; iconClass = 'bg-success-subtle text-success'; }
                        else if (msg.includes('medical record') || msg.includes('record')) { icon = 'fa-file-medical'; iconClass = 'bg-warning-subtle text-warning'; }
                        else if (msg.includes('invoice') || msg.includes('payment')) { icon = 'fa-file-invoice-dollar'; iconClass = 'bg-danger-subtle text-danger'; }

                        return `
                            <div class="notification-item ${item.isRead ? '' : 'unread'}"
                                 onclick="handleNotificationClick(${item.id}, '${item.targetUrl}', event)">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="header-icon-box ${iconClass}" style="width:36px; height:36px; min-width:36px;">
                                        <i class="fas ${icon}" style="font-size: 14px;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="notification-content text-dark mb-1">${item.message}</div>
                                        <div class="notification-time text-muted x-small">
                                            <i class="far fa-clock me-1"></i>${item.createdAt}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('');
                    });

                    // Update badge count live
                    const unreadCount = data.filter(n => !n.isRead).length;
                    document.querySelectorAll('.notiBadge').forEach(b => {
                        if (unreadCount > 0) {
                            b.textContent = unreadCount;
                            b.style.display = '';
                        } else {
                            b.style.display = 'none';
                        }
                    });
                });
        }

        function handleNotificationClick(id, targetUrl, e) {
            e.stopPropagation();
            fetch('/Notification/MarkAsRead/' + id, { method: 'POST' })
                .then(() => {
                    if (targetUrl && targetUrl !== '') {
                        window.location.href = targetUrl;
                    } else {
                        fetchNotifications();
                    }
                });
        }

        function markAsRead(id, e) {
            e.stopPropagation();
            fetch('/Notification/MarkAsRead/' + id, { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        fetchNotifications();
                    }
                });
        }

        function markAllAsRead(e) {
            e.stopPropagation();
            fetch('/Notification/MarkAllAsRead', { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        fetchNotifications();
                        document.querySelectorAll('.notiBadge').forEach(b => b.style.display = 'none');
                    }
                });
        }

        document.querySelectorAll('.notiBtn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const dropdown = this.parentElement.querySelector('.notiDropdown');
                const isShowing = dropdown.classList.contains('show');
                
                document.querySelectorAll('.notiDropdown.show').forEach(d => d.classList.remove('show'));
                
                if (!isShowing) {
                    dropdown.classList.add('show');
                    fetchNotifications();
                }
            });
        });

        $(document).on('click', function(event) {
            if (!$(event.target).closest('.notification-container').length) {
                $('.notiDropdown.show').removeClass('show');
            }
        });

        // Track last visited page for "Remember Me"
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            if (currentPath && !currentPath.includes('/Account/')) {
                const expires = new Date();
                expires.setTime(expires.getTime() + (30 * 24 * 60 * 60 * 1000));
                document.cookie = "LastVisitedPath=" + currentPath + ";expires=" + expires.toUTCString() + ";path=/";
            }
        });

        // Sidebar Toggle Logic for Mobile
        const sidebarToggle = document.getElementById('sidebarToggleMobile');
        const sidebar = document.querySelector('.sidebar');
        if (sidebarToggle && sidebar) {
            sidebarToggle.addEventListener('click', (e) => {
                e.stopPropagation();
                sidebar.classList.toggle('active');
                const icon = sidebarToggle.querySelector('i');
                if (sidebar.classList.contains('active')) {
                    icon.classList.replace('fa-bars', 'fa-times');
                } else {
                    icon.classList.replace('fa-times', 'fa-bars');
                }
            });

            document.addEventListener('click', (e) => {
                if (!sidebar.contains(e.target) && !sidebarToggle.contains(e.target) && sidebar.classList.contains('active')) {
                    sidebar.classList.remove('active');
                    sidebarToggle.querySelector('i').classList.replace('fa-times', 'fa-bars');
                }
            });
        }
    </script>
    <partial name="_VideoCallModal" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
