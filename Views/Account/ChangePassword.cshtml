@model CareFleet.Models.ChangePasswordViewModel
@{
    var role = Context.Session.GetString("UserRole");
    Layout = role switch
    {
        "Admin" => "~/Views/Shared/_AdminLayout.cshtml",
        "Doctor" => "~/Views/Shared/_DoctorLayout.cshtml",
        "Patient" => "~/Views/Shared/_PatientLayout.cshtml",
        _ => "~/Views/Shared/_Layout.cshtml"
    };
    ViewData["Title"] = "Security Settings";
    ViewBag.HeaderTitle = "Update Password";
    ViewBag.HideHeader = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/ChangePassword.css" asp-append-version="true" />
}

<div class="change-password-page fade-in">

    <!-- ─── Premium Header Card ─────────────────────────── -->
    <div class="premium-header-card">
        <div class="header-card-content">
            <div class="header-info">
                <div class="header-title-group mb-2" style="display: flex !important; align-items: center !important; gap: 15px !important;">
                    <div style="width:44px;height:44px;background:rgba(255,255,255,0.15);
                                border-radius:12px;display:flex;align-items:center;
                                justify-content:center;border:1px solid rgba(255,255,255,0.25);">
                        <i class="fas fa-shield-alt" style="color:#fff;font-size:1.1rem;"></i>
                    </div>
                    <h2 class="fw-800 text-white mb-0">@ViewBag.HeaderTitle</h2>
                </div>
                <p class="text-white mb-0" style="opacity:.75;">
                    Change your account password to ensure maximum security.
                </p>
            </div>
            <div class="header-actions">
                <a href="javascript:history.back()" class="btn-premium-light">
                    <i class="fas fa-arrow-left me-2"></i>Back to Settings
                </a>
            </div>
        </div>
        <div class="header-bg-pattern"></div>
    </div>

    <!-- ─── Centered Form Wrapper ────────────────────────── -->
    <div class="change-password-form-wrapper">
        <div class="security-card-premium">
            
            <div class="security-card-header text-center">
                <h3 class="fw-800 mb-2" style="color: #1B3C53; letter-spacing: -0.5px;">Change Password</h3>
                <p class="text-muted small">Verification is required to update your credentials.</p>
            </div>

            <form id="changePasswordForm">
                @Html.AntiForgeryToken()
                
                <div class="form-group-modern">
                    <label class="form-label-modern">Current Password</label>
                    <div class="input-lock-wrapper">
                        <input type="password" id="CurrentPassword" name="CurrentPassword" 
                               class="form-control-modern" placeholder="Verify current identity" required>
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('CurrentPassword')"></i>
                    </div>
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">New Strong Password</label>
                    <div class="input-lock-wrapper">
                        <input type="password" id="NewPassword" name="NewPassword" 
                               class="form-control-modern" placeholder="Minimum 6 characters" required>
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('NewPassword')"></i>
                    </div>
                </div>

                <div class="form-group-modern">
                    <label class="form-label-modern">Confirm New Password</label>
                    <div class="input-lock-wrapper">
                        <input type="password" id="ConfirmPassword" name="ConfirmPassword" 
                               class="form-control-modern" placeholder="Repeat new password" required>
                        <i class="fas fa-eye password-toggle" onclick="togglePassword('ConfirmPassword')"></i>
                    </div>
                </div>

                <button type="submit" class="btn-premium-action mt-4" id="submitBtn" 
                        style="border-radius: 50px; background: linear-gradient(135deg, #1B3C53, #437d9c); padding: 14px 20px; color: white !important;">
                    <i class="fas fa-sync-alt me-2" id="btnIcon"></i>
                    <span id="btnText">Update Identity Password</span>
                </button>


                <a href="javascript:history.back()" class="form-footer-link">
                    <i class="fas fa-times-circle me-1"></i> Cancel & Return
                </a>
            </form>

            <div class="security-hints-banner">
                <div class="hint-point">
                    <i class="fas fa-info-circle"></i>
                    <span>Use a unique password that you don't use for other online accounts.</span>
                </div>
                <div class="hint-point">
                    <i class="fas fa-info-circle"></i>
                    <span>Combining uppercase, lowercase, numbers, and symbols creates the strongest protection.</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = input.nextElementSibling;
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        document.getElementById('changePasswordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const currentPass = document.getElementById('CurrentPassword').value;
            const newPass = document.getElementById('NewPassword').value;
            const confirmPass = document.getElementById('ConfirmPassword').value;
            const submitBtn = document.getElementById('submitBtn');
            const btnIcon = document.getElementById('btnIcon');
            const btnText = document.getElementById('btnText');

            if (newPass !== confirmPass) {
                Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: 'New passwords do not match. Please try again.',
                    confirmButtonColor: '#1B3C53'
                });
                return;
            }

            // Set loading state
            submitBtn.disabled = true;
            btnIcon.classList.add('fa-spin');
            btnText.innerText = 'Synchronizing...';

            try {
                const response = await fetch('@Url.Action("ChangePassword", "Account")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        CurrentPassword: currentPass,
                        NewPassword: newPass,
                        ConfirmPassword: confirmPass
                    })
                });

                const result = await response.json();

                if (result.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: result.message,
                        confirmButtonColor: '#1B3C53'
                    });
                    
                    // Dynamic redirect based on role
                    const userRole = '@(Context.Session.GetString("UserRole"))';
                    let redirectUrl = '@Url.Action("Login", "Account")'; // Default fallback
                    
                    if (userRole === "Admin") {
                        redirectUrl = '@Url.Action("Settings", "Admin")';
                    } else if (userRole === "Doctor") {
                        redirectUrl = '@Url.Action("Settings", "Doctor")';
                    } else if (userRole === "Patient") {
                        redirectUrl = '@Url.Action("Dashboard", "Patient")';
                    }
                    
                    window.location.href = redirectUrl;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Update Failed',
                        text: result.message,
                        confirmButtonColor: '#1B3C53'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'System Error',
                    text: 'Could not connect to the server. Please try again later.',
                    confirmButtonColor: '#1B3C53'
                });
            } finally {
                submitBtn.disabled = false;
                btnIcon.classList.remove('fa-spin');
                btnText.innerText = 'Update Identity Password';
            }
        });
    </script>
}

