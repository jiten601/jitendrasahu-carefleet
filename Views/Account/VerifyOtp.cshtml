@{
    ViewData["Title"] = "Verify Email";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page-wrapper fade-in">
    <div class="auth-container">
        <div class="auth-card">

            <!-- Logo -->
            <div class="logo-container" style="text-align:center; margin-bottom:20px;">
                <img src="~/images/FinalLogo.png"
                     alt="CareFleet Logo"
                     style="max-width:200px; height:auto;" />
            </div>

            <h2 class="welcome-text">Email Verification</h2>

            <p style="text-align:center; margin-bottom:24px; color:#547792; font-size:0.95rem;">
                We have sent a 6-digit OTP to your email.<br />
                Please enter it below to verify your account.
            </p>

            <form asp-action="VerifyOtp" method="post" class="auth-form">

                <div class="form-group">
                    <label for="otp">OTP Code</label>
                    <input type="text"
                           id="otp"
                           name="otp"
                           placeholder="Enter 6-digit OTP"
                           maxlength="6"
                           required />
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="error-message">
                        @ViewBag.Error
                    </div>
                }

                <button type="submit" class="btn-primary">
                    Verify Account
                </button>

                <p class="auth-link">
                    Didn't receive the code?
                    <a asp-action="Register">Register again</a>
                </p>

            </form>
        </div>
    </div>
</div>
