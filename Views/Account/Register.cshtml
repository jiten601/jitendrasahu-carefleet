@model CareFleet.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page-wrapper fade-in">
    <div class="auth-container">
        <div class="auth-card">
            <div class="logo-container" style="text-align: center; margin-bottom: 20px;">
                <img src="~/images/FinalLogo.png" alt="CareFleet Logo" style="max-width: 200px; height: auto;" />
            </div>

            <h2 class="register-title">Create Your CareFleet Account</h2>

            <form asp-action="Register" method="post" class="auth-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                @Html.AntiForgeryToken()

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="FirstName">First Name</label>
                    <input asp-for="FirstName" placeholder="Enter your first name" required autocomplete="given-name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="LastName">Last Name</label>
                    <input asp-for="LastName" placeholder="Enter your last name" required autocomplete="family-name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" placeholder="e.g., john.doe@example.com" required autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="Role">Register As</label>
                    <select asp-for="Role" required>
                        <option value="" disabled selected>Select your role</option>
                        <option value="Patient">Patient</option>
                        <option value="Doctor">Doctor</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="Password">Password</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" placeholder="Enter your password" required autocomplete="new-password" />
                        <button type="button" class="toggle-password" id="passwordToggle">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <div class="password-wrapper">
                        <input asp-for="ConfirmPassword" placeholder="Re-enter your password" required autocomplete="new-password" />
                        <button type="button" class="toggle-password" id="confirmPasswordToggle">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div id="patientFields" style="display: none; grid-column: 1 / -1; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber" placeholder="Enter your phone number" class="patient-req" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="DateOfBirth">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="patient-req" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="Gender">Gender</label>
                        <select asp-for="Gender" class="patient-req">
                            <option value="" disabled selected>Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="BloodGroup">Blood Group</label>
                        <select asp-for="BloodGroup" class="patient-req">
                            <option value="" disabled selected>Select blood group</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                        </select>
                        <span asp-validation-for="BloodGroup" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0; grid-column: 1 / -1;">
                        <label asp-for="Address">Address</label>
                        <input asp-for="Address" placeholder="Enter your full address" class="patient-req" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="MedicalHistory">Medical History</label>
                        <textarea asp-for="MedicalHistory" placeholder="Any relevant past medical history"></textarea>
                        <span asp-validation-for="MedicalHistory" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Allergies">Allergies (Optional)</label>
                        <textarea asp-for="Allergies" placeholder="List any allergies"></textarea>
                        <span asp-validation-for="Allergies" class="text-danger"></span>
                    </div>
                </div>

                <div id="doctorFields" style="display: none; grid-column: 1 / -1; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="Specialization">Specialization</label>
                        <select asp-for="Specialization" class="doctor-req">
                            <option value="" disabled selected>Select specialization</option>
                            <option value="General Physician">General Physician</option>
                            <option value="Cardiologist">Cardiologist</option>
                            <option value="Dermatologist">Dermatologist</option>
                            <option value="Neurologist">Neurologist</option>
                            <option value="Orthopedic">Orthopedic</option>
                            <option value="Pediatrician">Pediatrician</option>
                            <option value="Psychiatrist">Psychiatrist</option>
                            <option value="Surgeon">Surgeon</option>
                        </select>
                        <span asp-validation-for="Specialization" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="LicenseNumber">Medical License Number</label>
                        <input asp-for="LicenseNumber" placeholder="Enter License ID" class="doctor-req" />
                        <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0; grid-column: 1 / -1;">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber" id="doctorPhoneNumber" placeholder="Enter contact number" class="doctor-req" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <!-- Spacer to force Error, Button, and Link to span both columns or re-flow logically -->
                <div style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 15px; margin-top: 10px;">

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-message">
                            @ViewBag.Error
                        </div>
                    }

                    <button type="submit" class="btn-primary" style="margin-bottom: 5px;">Register Account</button>

                    <div class="divider" style="grid-column: 1 / -1; margin: 5px 0;">
                        <span>OR</span>
                    </div>

                    <p class="auth-link">
                        Already have an account? <a asp-action="Login">Login here</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Password match validation
        const passwordInput = document.getElementById('Password');
        const confirmPasswordInput = document.getElementById('ConfirmPassword');

        confirmPasswordInput.addEventListener('input', function() {
            const password = passwordInput.value;
            const confirmPassword = this.value;

            if (confirmPassword && password !== confirmPassword) {
                this.setCustomValidity('Passwords do not match');
            } else {
                this.setCustomValidity('');
            }
        });

        // Toggle Password Visibility
        function setupPasswordToggle(inputId, toggleId) {
            const input = document.getElementById(inputId);
            const toggle = document.getElementById(toggleId);
            const icon = toggle.querySelector('i');

            toggle.addEventListener('click', function() {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);

                icon.classList.toggle('bi-eye');
                icon.classList.toggle('bi-eye-slash');
            });
        }

        setupPasswordToggle('Password', 'passwordToggle');
        setupPasswordToggle('ConfirmPassword', 'confirmPasswordToggle');

        // Dynamic Fields Toggle
        const roleSelect = document.getElementById('Role');
        const patientFields = document.getElementById('patientFields');
        const doctorFields = document.getElementById('doctorFields');
        const patientReqInputs = document.querySelectorAll('.patient-req');
        const doctorReqInputs = document.querySelectorAll('.doctor-req');

        function toggleRoleFields() {
            const role = roleSelect.value;

            // Reset all
            patientFields.style.display = 'none';
            doctorFields.style.display = 'none';
            
            // Disable all fields in both hidden sections first
            patientFields.querySelectorAll('input, select, textarea').forEach(input => {
                input.disabled = true;
                input.removeAttribute('required');
            });
            doctorFields.querySelectorAll('input, select, textarea').forEach(input => {
                input.disabled = true;
                input.removeAttribute('required');
            });

            if (role === 'Patient') {
                patientFields.style.display = 'grid';
                patientFields.querySelectorAll('input, select, textarea').forEach(input => {
                    input.disabled = false;
                });
                patientReqInputs.forEach(input => input.setAttribute('required', 'required'));
            } else if (role === 'Doctor') {
                doctorFields.style.display = 'grid';
                doctorFields.querySelectorAll('input, select, textarea').forEach(input => {
                    input.disabled = false;
                });
                doctorReqInputs.forEach(input => input.setAttribute('required', 'required'));
            }
        }

        roleSelect.addEventListener('change', toggleRoleFields);

        // Trigger on load
        toggleRoleFields();
    </script>
}

