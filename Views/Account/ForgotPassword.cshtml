@model CareFleet.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CareFleet - Forgot Password</title>

    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>

<body>
    <div class="auth-container">
        <div class="auth-card">

            <div class="logo-container" style="text-align:center; margin-bottom:20px;">
                <img src="~/images/FinalLogo.png"
                     alt="CareFleet Logo"
                     style="max-width:200px; height:auto;" />
            </div>

            <h2 class="welcome-text">Reset Your Password</h2>
            
            <p style="text-align:center; margin-bottom:20px; color:#547792;">
                Enter your email address and we'll send you an OTP to reset your password.
            </p>

            <form asp-controller="Account"
                  asp-action="ForgotPassword"
                  method="post"
                  class="auth-form">

                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email"
                           placeholder="Enter your registered email"
                           required
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                @if (ViewBag.Message != null)
                {
                    <div class="success-message" style="background-color:#e6fffa; border:1px solid #b2f5ea; color:#2c7a7b; padding:12px; border-radius:8px; margin-bottom:20px; text-align:left;">
                        @ViewBag.Message
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="error-message">
                        @ViewBag.Error
                    </div>
                }

                <button type="submit" class="btn-primary">
                    Send OTP
                </button>

                <div class="auth-link">
                    Remembered your password?
                    <a asp-controller="Account" asp-action="Login">Back to Login</a>
                </div>

            </form>
        </div>
    </div>
</body>
</html>
